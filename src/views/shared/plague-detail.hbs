            <span class="material-symbols-outlined text-sm mx-1">chevron_right</span>
            <span class="text-primary font-bold">{{plague.name}}</span>
          </div>
        </li>
      </ol>
    </nav>

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h1 class="text-5xl md:text-6xl font-headline font-extrabold text-on-surface tracking-tighter mb-2">
          {{plague.name}}
        </h1>
        <p class="text-lg text-on-surface-variant font-medium">
          Análisis fitosanitario avanzado de
          <span class="italic">{{plague.scientificName}}</span>
        </p>
      </div>
      <div>
        <button
          class="flex items-center gap-2.5 px-5 py-3 bg-surface-container text-on-surface font-semibold text-sm rounded-xl hover:bg-surface-container-high active:scale-95 transition-all shadow-xs">
          <span class="material-symbols-outlined text-lg leading-none" style="font-variation-settings: 'wght' 300;">add_circle</span>
          Proponer nuevo registro
