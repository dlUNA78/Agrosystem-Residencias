          </div>
          {{/each}}
          {{! Si no hay imágenes adicionales ni imagen principal, mostrar placeholder }}
          {{#unless plague.imageUrl}}{{#unless carouselImages}}
          <div class="flex-none w-[300px] md:w-[380px]" style="scroll-snap-align:start;">
            <div
              class="overflow-hidden rounded-xl bg-surface-container-highest mb-3 relative flex items-center justify-center"
              style="aspect-ratio:4/3;">
              <div class="text-center p-8">
                <span
                  class="material-symbols-outlined text-5xl text-on-surface-variant/40 mb-4 block">image_search</span>
                <p class="text-xs text-on-surface-variant font-medium">Imágenes de referencia no disponibles</p>
              </div>
            </div>
            <span
              class="text-[10px] text-on-surface-variant uppercase tracking-widest px-1 font-bold block">INIFAP</span>
          </div>
          {{/unless}}{{/unless}}
        </div>
      </div>
    </div>

    {{! Sidebar: región e incidencia }}
    <div class="col-span-1 lg:col-span-5">
      <div class="bg-surface-container p-6 md:p-8 rounded-xl sticky top-28">
        <h2 class="text-xl font-headline font-extrabold tracking-tight mb-6">Información de Incidencia</h2>

        {{! Región principal }}
        <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10 mb-4">
          <h3 class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2">Región Principal</h3>
          <p class="text-base font-bold text-on-surface">{{plague.region}}</p>
        </div>

        {{! Nivel de riesgo visual }}
        <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10 mb-4">
          <h3 class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-3">Nivel de Riesgo
            Registrado</h3>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary"
              style="font-variation-settings:'FILL' 1;">warning</span>
            <span class="px-3 py-1 rounded-full text-xs font-bold {{plague.riskBadgeClass}}">{{plague.riskLabel}}</span>
          </div>
        </div>

        {{! Acciones rápidas }}
        <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10">
          <h3 class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-4">Acciones Rápidas</h3>
          <div class="space-y-3">
            <a href="/plagues" class="flex items-center gap-2 text-sm font-bold text-primary hover:underline">
              <span class="material-symbols-outlined text-sm">arrow_back</span>
              Volver al catálogo
            </a>
            <a href="/products" class="flex items-center gap-2 text-sm font-bold text-primary hover:underline">
              <span class="material-symbols-outlined text-sm">science</span>
              Ver productos recomendados
            </a>
            {{#if isPrivate}}
            <a href="/private/plagues/{{plague.id}}/edit"
              class="flex items-center gap-2 text-sm font-bold text-primary hover:underline">
              <span class="material-symbols-outlined text-sm">edit</span>
              Editar registro
            </a>
            {{/if}}
          </div>
        </div>
      </div>
    </div>
  </div>

  {{! ── PRODUCTOS RECOMENDADOS ──────────────────────────────────────────── }}
  <div class="mb-24">
    <h2 class="text-2xl font-headline font-extrabold tracking-tight mb-8">Productos Recomendados Validados por INIFAP
    </h2>

    {{#if relatedProducts}}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      {{#each relatedProducts}}
      <div
        class="bg-white p-6 rounded-xl border border-outline-variant/15 shadow-sm hover:shadow-md transition-shadow flex flex-col">
        <div class="flex justify-between items-start mb-4">
          <span class="material-symbols-outlined text-primary text-3xl">science</span>
          {{#if this.isValidated}}
          <span
            class="inline-flex items-center gap-1 px-2 py-1 bg-primary/10 text-primary text-[10px] font-bold uppercase tracking-wider rounded">
            <span class="material-symbols-outlined text-xs" style="font-variation-settings:'FILL' 1;">verified</span>
            Validado INIFAP
          </span>
          {{/if}}
        </div>
        {{#if this.imageUrl}}
        <div class="mb-4 overflow-hidden rounded-lg bg-surface-container-low aspect-square">
          <img alt="{{this.name}}" class="w-full h-full object-contain p-4" src="{{this.imageUrl}}" />
        </div>
        {{/if}}
        <h4 class="text-lg font-headline font-bold text-on-surface mb-1">{{this.name}}</h4>
        <p class="text-sm font-medium text-primary mb-3">{{this.activeIngredient}}</p>
        <div class="pt-3 border-t border-outline-variant/10 mb-4 flex-1">
          <span class="text-[10px] text-on-surface-variant uppercase tracking-widest font-bold">Fabricante</span>
          <p class="text-sm font-semibold text-on-surface">{{this.manufacturer}}</p>
        </div>
        <a href="/products/{{this.id}}"
          class="flex items-center justify-center gap-2 w-full py-2.5 bg-primary text-on-primary text-sm font-bold rounded-lg hover:bg-primary-dim transition-colors">
          Ver producto
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="bg-surface-container-low rounded-xl p-10 text-center mb-8">
      <span class="material-symbols-outlined text-4xl text-on-surface-variant/40 mb-3 block">science_off</span>
      <p class="text-sm text-on-surface-variant">Aún no hay productos específicos vinculados a esta plaga.</p>
    </div>
    {{/if}}

    <div class="text-center">
      <a href="/products"
        class="inline-flex items-center gap-2 px-6 py-3 border-2 border-primary text-primary font-bold text-sm rounded-xl hover:bg-primary hover:text-on-primary transition-all">
        <span class="material-symbols-outlined text-sm">open_in_new</span>
        Ver todos los productos en el catálogo
      </a>
    </div>
  </div>

</div>