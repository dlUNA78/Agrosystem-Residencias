      </div>
    </div>
  </div>

  {{! ── HERO CARRUSEL + RISK BADGE ────────────────────────────────────── }}
  <div class="mb-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">

      {{! Carrusel principal }}
      <div class="col-span-1 lg:col-span-8">
        <div class="relative overflow-hidden rounded-xl bg-surface-container-low shadow-sm mb-3 h-[500px] group"
          id="hero-carousel">

          {{! Slides }}
          <div class="flex h-full transition-transform duration-700 ease-in-out" id="hero-slides">
            {{! Slide 0: imagen principal de la plaga }}
            {{#if plague.imageUrl}}
            <div class="flex-none w-full h-full relative" style="min-width:100%">
              <img class="w-full h-full object-cover" src="{{plague.imageUrl}}" alt="{{plague.name}} — Vista general" />
              <div class="absolute inset-0 bg-linear-to-t from-black/50 via-transparent to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <span class="text-white/70 text-[10px] uppercase tracking-widest font-bold block mb-1">Vista
                  General</span>
                <p class="text-white text-lg font-headline font-bold">{{plague.name}}</p>
              </div>
            </div>
            {{/if}}
            {{! Slides adicionales desde PlagueImages }}
            {{#each carouselImages}}
            <div class="flex-none w-full h-full relative" style="min-width:100%">
              <img class="w-full h-full object-cover" src="{{this.url}}" alt="{{this.caption}}" />
              <div class="absolute inset-0 bg-linear-to-t from-black/50 via-transparent to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <span
                  class="text-white/70 text-[10px] uppercase tracking-widest font-bold block mb-1">{{this.source}}</span>
                <p class="text-white text-lg font-headline font-bold">{{this.caption}}</p>
              </div>
            </div>
            {{/each}}
            {{! Fallback si no hay ninguna imagen }}
            {{#unless plague.imageUrl}}{{#unless carouselImages}}
            <div class="flex-none w-full h-full bg-surface-container-highest flex items-center justify-center"
              style="min-width:100%">
              <span class="material-symbols-outlined text-6xl text-on-surface-variant">pest_control</span>
            </div>
            {{/unless}}{{/unless}}
          </div>

          {{! Botón prev }}
          <button id="hero-prev"
            class="absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/30 hover:bg-black/60 text-white flex items-center justify-center transition-all opacity-0 group-hover:opacity-100 backdrop-blur-sm"
            aria-label="Anterior">
            <span class="material-symbols-outlined">chevron_left</span>
          </button>
          {{! Botón next }}
          <button id="hero-next"
            class="absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/30 hover:bg-black/60 text-white flex items-center justify-center transition-all opacity-0 group-hover:opacity-100 backdrop-blur-sm"
            aria-label="Siguiente">
            <span class="material-symbols-outlined">chevron_right</span>
          </button>

          {{! Indicadores }}
          <div id="hero-dots" class="absolute bottom-16 right-5 flex gap-1.5">
            {{! Los dots se generan por JS }}
          </div>

          {{! Badge INIFAP }}
          <div
            class="absolute top-4 right-4 flex items-center gap-1 px-3 py-1 bg-black/30 backdrop-blur-sm rounded-full">
            <span class="material-symbols-outlined text-primary text-sm"
              style="font-variation-settings:'FILL' 1;">verified</span>
            <span class="text-white text-[10px] font-bold uppercase tracking-widest">INIFAP</span>
          </div>
        </div>

        <span class="text-[10px] text-on-surface-variant uppercase tracking-widest px-1 font-bold"
          id="hero-source-label">
          Imagen por: Banco de Germoplasma INIFAP
        </span>
      </div>

      {{! Panel de riesgo }}
      <div class="col-span-1 lg:col-span-4 flex flex-col gap-6">
        <div class="flex-1 p-6 md:p-8 rounded-xl flex flex-col justify-end text-white
            {{plague.riskGradientClass}}">
          <span class="text-white/80 text-xs font-bold uppercase tracking-widest mb-2">Estado de Riesgo</span>
          <div class="flex items-center gap-2">
            <div class="text-4xl font-headline font-extrabold tracking-tighter">{{plague.riskLabel}}</div>
            <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">warning</span>
          </div>
          <p class="text-white/90 text-sm mt-4 leading-relaxed">{{plague.description}}</p>
        </div>
        <div class="bg-surface-container-lowest border-l-4 border-primary p-6 md:p-8 rounded-xl shadow-sm">
          <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-3">Validación
            Científica</span>
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary mt-0.5"
              style="font-variation-settings: 'FILL' 1;">verified</span>
            <div>
              <p class="text-base font-headline font-bold text-on-surface leading-tight">
                {{#if plague.verifiedBy}}{{plague.verifiedBy}}{{else}}INIFAP{{/if}}
              </p>
              {{#if plague.verifiedAt}}
              <p class="text-xs text-on-surface-variant mt-1">
                <span class="material-symbols-outlined text-xs align-middle mr-0.5">calendar_today</span>
                Verificado el {{plague.verifiedAt}}
              </p>
              {{else}}
              <p class="text-xs text-on-surface-variant mt-1">Instituto Nacional de Investigaciones Forestales,
                Agrícolas y Pecuarias</p>
              {{/if}}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function () {
      const slides = document.getElementById('hero-slides');
      const prevBtn = document.getElementById('hero-prev');
      const nextBtn = document.getElementById('hero-next');
      const dotsWrap = document.getElementById('hero-dots');
      const srcLabel = document.getElementById('hero-source-label');

      const items = slides ? slides.children : [];
      const total = items.length;
      if (total <= 1) {
        if (prevBtn) prevBtn.style.display = 'none';
        if (nextBtn) nextBtn.style.display = 'none';
        return;
      }

      const sources = Array.from(items).map(el => {
        const caption = el.querySelector('p');
        return caption ? caption.textContent.trim() : 'Banco de Germoplasma INIFAP';
      });

      let current = 0;
      let timer;

      // Crear dots
      for (let i = 0; i < total; i++) {
        const dot = document.createElement('button');
        dot.className = 'w-2 h-2 rounded-full transition-all ' + (i === 0 ? 'bg-white w-5' : 'bg-white/40');
        dot.setAttribute('aria-label', 'Slide ' + (i + 1));
        dot.addEventListener('click', () => goTo(i));
        dotsWrap.appendChild(dot);
      }

      function goTo(n) {
        current = (n + total) % total;
        slides.style.transform = 'translateX(-' + (current * 100) + '%)';
        Array.from(dotsWrap.children).forEach((d, i) => {
          d.className = 'h-2 rounded-full transition-all ' + (i === current ? 'bg-white w-5' : 'bg-white/40 w-2');
        });
        if (srcLabel) srcLabel.textContent = 'Imagen por: ' + sources[current];
        resetTimer();
      }

      function resetTimer() {
        clearInterval(timer);
        timer = setInterval(() => goTo(current + 1), 5000);
      }

      if (prevBtn) prevBtn.addEventListener('click', () => goTo(current - 1));
      if (nextBtn) nextBtn.addEventListener('click', () => goTo(current + 1));

      resetTimer();
    })();
  </script>

  {{! ── FICHA TÉCNICA ────────────────────────────────────────────────────── }}
  <div class="mb-24">
    <h2 class="text-2xl font-headline font-extrabold tracking-tight mb-8">Ficha Técnica Completa</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10">
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2">Nombre Científico</h3>
        <p class="text-base font-bold italic text-on-surface leading-tight">{{plague.scientificName}}</p>
      </div>
      <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10">
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2">Clasificación</h3>
        <p class="text-base font-bold text-on-surface leading-tight">{{plague.category}}</p>
      </div>
      <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10">
