          <p class="text-[10px] text-on-surface-variant uppercase tracking-widest font-bold mb-5">
            Cartografía: SIAP / INIFAP 2024
          </p>

          {{! Lista de regiones }}
          <div>
            <h3 class="text-[10px] font-bold uppercase tracking-widest text-primary mb-4">Regiones Monitoreadas</h3>
            <div class="space-y-0">
              {{#each incidenceRegions}}
              <div class="flex items-center justify-between py-3 border-b border-outline-variant/10 last:border-0">
                <span class="text-sm font-medium text-on-surface">{{this.name}}</span>
                <span class="px-2.5 py-1 text-[10px] font-bold uppercase rounded-full {{this.riskBadgeClass}}">{{this.riskLabel}}</span>
              </div>
              {{/each}}
            </div>
          </div>
        </div>
      </div>

      {{! Panel informativo complementario }}
      <div class="col-span-1 lg:col-span-7">
        <div class="h-full flex flex-col gap-6 justify-center">
          <div>
            <span class="text-[10px] font-bold uppercase tracking-widest text-primary block mb-3">Zona de Alerta</span>
            <h3 class="text-2xl font-headline font-extrabold tracking-tight mb-3">Distribución Geográfica</h3>
            <p class="text-on-surface-variant leading-relaxed">
              Las regiones marcadas en el mapa corresponden a zonas con historial documentado de presencia de <em>{{plague.name}}</em>.
              La cartografía se basa en reportes de campo del SIAP y estaciones de monitoreo del INIFAP actualizados para el ciclo agrícola vigente.
            </p>
          </div>

          <div class="grid grid-cols-3 gap-4">
            <div class="bg-surface-container-low p-4 rounded-xl border border-outline-variant/10 text-center">
              <span class="text-3xl font-headline font-extrabold text-primary block">{{incidenceRegions.length}}</span>
              <span class="text-[10px] text-on-surface-variant uppercase tracking-widest font-bold">Regiones</span>
            </div>
            <div class="bg-surface-container-low p-4 rounded-xl border border-outline-variant/10 text-center">
              <span class="text-3xl font-headline font-extrabold text-primary block">2024</span>
              <span class="text-[10px] text-on-surface-variant uppercase tracking-widest font-bold">Ciclo agrícola</span>
            </div>
            <div class="bg-surface-container-low p-4 rounded-xl border border-outline-variant/10 text-center">
              <span class="inline-block px-2 py-1 rounded-full text-xs font-bold {{plague.riskBadgeClass}}">{{plague.riskLabel}}</span>
              <span class="text-[10px] text-on-surface-variant uppercase tracking-widest font-bold block mt-1">Nivel</span>
            </div>
          </div>

          <div class="flex items-center gap-6 flex-wrap">
            <div class="flex items-center gap-2">
              <span class="w-4 h-4 rounded-full bg-error inline-block"></span>
              <span class="text-xs text-on-surface-variant font-medium">Crítico</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-4 h-4 rounded-full bg-primary inline-block"></span>
              <span class="text-xs text-on-surface-variant font-medium">Moderado</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-4 h-4 rounded-full bg-secondary inline-block"></span>
              <span class="text-xs text-on-surface-variant font-medium">Bajo</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {{! Script de inicialización del mapa — espera a que Leaflet cargue }}
  <script>
    window.addEventListener('load', function () {
      const mapEl = document.getElementById('incidence-map');
      if (!mapEl || typeof L === 'undefined') return;

      const regions    = {{{incidenceRegionsJson}}};
      const riskLevel  = '{{plague.riskLevel}}';
      const riskColors = {
        'Alto':  '#9f403d',
        'Medio': '#43655c',
        'Bajo':  '#50635f',
      };
      const markerColor = riskColors[riskLevel] || riskColors['Medio'];

      const map = L.map('incidence-map', {
        center: [23.6345, -102.5528],
        zoom: 5,
        zoomControl: true,
        scrollWheelZoom: false,
        attributionControl: false,
      });

      L.tileLayer(
        'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',
        { maxZoom: 19, subdomains: 'abcd' }
      ).addTo(map);

      const bounds = [];
      regions.forEach(function (r) {
        const circle = L.circleMarker([r.lat, r.lng], {
          radius:      10,
          fillColor:   markerColor,
          color:       markerColor,
          weight:      2,
          opacity:     0.9,
          fillOpacity: 0.35,
        }).addTo(map);

        circle.bindPopup(
          '<div style="font-family: Inter, sans-serif; min-width: 140px;">'
          + '<p style="font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:#596061;margin:0 0 4px;">Zona de Alta Incidencia</p>'
          + '<p style="font-weight:700;font-size:14px;margin:0;color:#2d3435;">' + r.name + '</p>'
          + '</div>',
          { closeButton: false }
        );

        if (r.hasCoords) bounds.push([r.lat, r.lng]);
      });

      if (bounds.length > 1) {
        map.fitBounds(bounds, { padding: [40, 40], maxZoom: 7 });
      } else if (bounds.length === 1) {
        map.setView(bounds[0], 7);
      }
    });
  </script>
  {{/if}}

  {{! ── CICLO BIOLÓGICO ────────────────────────────────────────────────── }}
  <div class="bg-surface-container-low py-16 px-8 rounded-2xl mb-24">
