<main class="pt-32 pb-24">
  <!-- Header Section -->
  <header class="max-w-[1440px] mx-auto px-10 mb-16">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
      <div class="max-w-2xl">
        <span
          class="inline-block px-3 py-1 mb-4 rounded-full bg-primary-container text-on-primary-container font-label text-xs font-bold tracking-wider uppercase"
        >Base de Datos Científica</span>
        <h1
          class="text-5xl md:text-6xl font-headline font-extrabold tracking-tighter text-on-surface mb-4"
        >
          Catálogo de Plagas</h1>
        <p class="text-on-surface-variant text-lg font-medium leading-relaxed">
          Explora nuestra enciclopedia especializada de agentes biológicos.
          Información técnica para la gestión inteligente de cultivos.
        </p>
      </div>
      <div
        class="bg-surface-container rounded-xl p-6 ghost-border flex flex-col items-center justify-center min-w-[200px]"
      >
        <span
          class="text-4xl font-headline font-extrabold text-primary tracking-tighter"
        >{{totalCount}}</span>
        <span
          class="text-xs font-label uppercase tracking-widest text-on-surface-variant font-bold mt-1"
        >especies registradas</span>
      </div>
    </div>
    <!-- Search & Filters -->
    <div class="mt-12 p-2 bg-surface-container-low rounded-2xl ghost-border">
      <div class="flex flex-col lg:flex-row gap-2">
        <div class="flex-1 relative flex items-center">
          <span
            class="material-symbols-outlined absolute left-4 text-on-surface-variant"
          >search</span>
          <input
            class="w-full bg-surface-container-lowest border-none rounded-xl py-4 pl-12 pr-4 text-on-surface placeholder:text-on-surface-variant/60 focus:ring-2 focus:ring-primary/20 transition-all font-body"
            placeholder="Buscar por nombre, género o síntoma..."
            type="text"
          />
        </div>
        <div class="flex flex-wrap md:flex-nowrap gap-2">
          <select
            class="bg-surface-container-lowest border-none rounded-xl py-4 px-6 text-sm font-semibold text-on-surface-variant focus:ring-2 focus:ring-primary/20 appearance-none min-w-[140px]"
          >
            <option>Categoría</option>
            <option>Insectos</option>
            <option>Hongos</option>
            <option>Bacterias</option>
            <option>Virus</option>
          </select>
          <select
            class="bg-surface-container-lowest border-none rounded-xl py-4 px-6 text-sm font-semibold text-on-surface-variant focus:ring-2 focus:ring-primary/20 appearance-none min-w-[140px]"
          >
            <option>Región</option>
            <option>Tropical</option>
            <option>Mediterránea</option>
            <option>Templada</option>
          </select>
          <select
            class="bg-surface-container-lowest border-none rounded-xl py-4 px-6 text-sm font-semibold text-on-surface-variant focus:ring-2 focus:ring-primary/20 appearance-none min-w-[140px]"
          >
            <option>Riesgo</option>
            <option>Crítico</option>
            <option>Moderado</option>
            <option>Bajo</option>
          </select>
          <button
            class="bg-primary text-on-primary px-8 py-4 rounded-xl font-bold text-sm hover:bg-primary-dim transition-colors flex items-center gap-2"
          >
            <span class="material-symbols-outlined text-sm">filter_list</span>
            Filtrar Resultados
          </button>
        </div>
      </div>
    </div>
  </header>
  <!-- Catalog Grid -->
  <section class="max-w-[1440px] mx-auto px-10">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8"
    >

      {{#each plagues}}
        <article
          class="group bg-surface-container-lowest rounded-xl overflow-hidden editorial-shadow ghost-border flex flex-col hover:translate-y-[-4px] transition-all duration-300"
        >
          <div class="relative h-56 overflow-hidden">
            <img
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              src="{{this.imageUrl}}"
              alt="{{this.name}}"
            />
            <div class="absolute top-4 left-4">
              <span
                class="px-2 py-1 rounded
                  {{this.riskBadgeClass}}
                  text-[10px] font-bold uppercase tracking-wider"
              >
                {{this.riskLabel}}
              </span>
            </div>
          </div>
          <div class="p-6 flex-1 flex flex-col">
            <span
              class="text-[10px] font-label font-bold uppercase tracking-widest text-primary mb-2"
            >
              {{this.category}}
            </span>
            <h3
              class="text-xl font-headline font-bold text-on-surface mb-1 leading-tight"
            >
              {{this.name}}
            </h3>
            <p class="text-sm italic text-on-surface-variant mb-4">
              {{this.scientificName}}
            </p>
            <p
              class="text-sm text-on-surface-variant line-clamp-2 leading-relaxed mb-6"
            >
              {{this.description}}
            </p>
            <div
              class="mt-auto pt-4 border-t border-surface-container flex justify-between items-center"
            >
              <a
                href="/plagues/{{this.id}}"
                class="text-primary font-bold text-sm flex items-center gap-1 group/btn"
              >
                Ver detalle
                <span
                  class="material-symbols-outlined text-sm group-hover/btn:translate-x-1 transition-transform"
                >arrow_forward</span>
              </a>
            </div>
          </div>
        </article>
      {{/each}}

      {{! Card CTA fija al final }}
      <article
        class="group bg-surface-container-lowest rounded-xl overflow-hidden editorial-shadow ghost-border flex flex-col hover:translate-y-[-4px] transition-all duration-300 border-2 border-dashed border-primary/20 items-center justify-center p-8"
      >
        <div class="text-center">
          <span
            class="material-symbols-outlined text-4xl text-primary/40 mb-4"
          >add_circle</span>
          <h3
            class="text-lg font-headline font-bold text-on-surface mb-2"
          >¿Nueva especie?</h3>
          <p class="text-xs text-on-surface-variant leading-relaxed mb-6">
            Colabora con nuestra red científica reportando una nueva plaga.
          </p>
          <button
            class="px-6 py-2 bg-surface-container-high rounded-full text-xs font-bold text-primary uppercase tracking-wider hover:bg-primary-container transition-colors"
          >
            Solicitar registro
          </button>
        </div>
      </article>

    </div>

    {{! Contador dinámico debajo del grid }}
    <p class="mt-8 text-center text-sm text-on-surface-variant">
      Mostrando
      {{totalCount}}
      plagas registradas
    </p>

    {{! Paginación — estática por ahora, se dinamiza en la tarea de paginación }}
    <div class="mt-12 flex justify-center">
      <nav class="flex items-center gap-1 bg-surface-container p-1 rounded-xl">
        <button
          class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-surface-container-highest text-on-surface-variant"
        >
          <span class="material-symbols-outlined">chevron_left</span>
        </button>
        <button
          class="w-10 h-10 flex items-center justify-center rounded-lg bg-primary text-on-primary font-bold text-sm"
        >1</button>
        <button
          class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-surface-container-highest text-on-surface-variant"
        >
          <span class="material-symbols-outlined">chevron_right</span>
        </button>
      </nav>
    </div>

  </section>
</main>