<main class="pt-24">
  <!-- Hero Section -->
  <section class="px-6 md:px-24 py-20 md:py-32 max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-16">
    <div class="flex-1 space-y-8">
      <div
        class="inline-flex items-center px-3 py-1 rounded-full bg-secondary-container text-on-secondary-container text-xs font-semibold tracking-wider uppercase"
        style="">
        Plataforma Oficial
      </div>
      <h1 class="text-5xl md:text-7xl font-headline font-extrabold tracking-tighter text-on-surface leading-[1.1]"
        style="">
        Información Agrícola <span class="text-primary" style="">Verificada</span> de México
      </h1>
      <p class="text-lg text-on-surface-variant max-w-lg leading-relaxed font-body" style="">
        Acceda a la base de datos más completa y precisa sobre sanidad vegetal, optimización de cultivos y productos
        especializados para el campo mexicano.
      </p>
      <div class="flex flex-wrap gap-4 pt-4">
        <button
          class="px-8 py-4 bg-primary text-on-primary font-headline font-bold rounded-lg hover:bg-primary-dim transition-all active:scale-95 flex items-center gap-2"
          style="">
          Explorar <span class="material-symbols-outlined text-sm" style="">arrow_forward</span>
        </button>
        <button
          class="px-8 py-4 bg-surface-container-high text-on-surface font-headline font-bold rounded-lg hover:bg-surface-container-highest transition-all active:scale-95"
          style="">
          Guía de Uso
        </button>
      </div>
    </div>
    <div class="flex-1 w-full relative">
      <div class="aspect-square rounded-3xl overflow-hidden bg-surface-container-low shadow-2xl">
        <img alt="Vista aérea de cultivos" class="w-full h-full object-cover mix-blend-multiply opacity-90"
          data-alt="Vista aérea de campos de cultivo geométricos"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuDvdCkY68Hne7ag8w5eIgNDx1ZVVAsIVGdYus5VN75UuM70f-dRSS_dRG4-y1xvb5gzbpy7WAL8BeANXjm404YMtivm1-kF-xOWFo5tpLYHNyjMW9sk__nyTDpEN6YvX2ZqkOQ9xA8vctoLMYA1BlLp8Id_SSbaJrSdlkaT9lXnQ8LJQsOqjrNEibxgqfPWIa_11yumizIN2Io_AMzYzeUtfZzASv-WQlCgD9e0S1a-Aze_BUPzYvvQSxo5AbgDnFzL69hlYi1J16Jo"
          style="">
      </div>
      <div class="absolute -bottom-8 -left-8 bg-white p-6 rounded-2xl shadow-xl border border-outline-variant/10">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-primary-container flex items-center justify-center text-primary">
            <span class="material-symbols-outlined" style="">verified</span>
          </div>
          <div>
            <p class="text-sm font-bold font-headline" style="">Certificación 2024</p>
            <p class="text-xs text-on-surface-variant" style="">Datos validados por expertos</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Statistics Row -->
  <section class="bg-surface-container-low py-16">
    <div class="max-w-7xl mx-auto px-6 md:px-24">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Stat 1 -->
        <div
          class="bg-surface-container-lowest p-8 rounded-xl flex items-center gap-6 shadow-sm border-l-4 border-primary">
          <div class="p-3 bg-secondary-container rounded-lg text-primary">
            <span class="material-symbols-outlined text-3xl" style="">pest_control</span>
          </div>
          <div>
            <div class="text-3xl font-headline font-extrabold text-on-surface" style="">1.2k</div>
            <div class="text-sm font-label font-medium uppercase tracking-widest text-on-surface-variant" style="">
              Plagas</div>
          </div>
        </div>
        <!-- Stat 2 -->
        <div
          class="bg-surface-container-lowest p-8 rounded-xl flex items-center gap-6 shadow-sm border-l-4 border-primary">
          <div class="p-3 bg-secondary-container rounded-lg text-primary">
            <span class="material-symbols-outlined text-3xl" style="">potted_plant</span>
          </div>
          <div>
            <div class="text-3xl font-headline font-extrabold text-on-surface" style="">450</div>
            <div class="text-sm font-label font-medium uppercase tracking-widest text-on-surface-variant" style="">
              Cultivos</div>
          </div>
        </div>
        <!-- Stat 3 -->
        <div
          class="bg-surface-container-lowest p-8 rounded-xl flex items-center gap-6 shadow-sm border-l-4 border-primary">
          <div class="p-3 bg-secondary-container rounded-lg text-primary">
            <span class="material-symbols-outlined text-3xl" style="">inventory_2</span>
          </div>
          <div>
            <div class="text-3xl font-headline font-extrabold text-on-surface" style="">800</div>
            <div class="text-sm font-label font-medium uppercase tracking-widest text-on-surface-variant" style="">
              Productos</div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Search Section -->
  <section class="px-6 md:px-24 py-24 max-w-5xl mx-auto text-center">
    <h2 class="text-3xl font-headline font-bold mb-12 text-on-surface tracking-tight" style="">¿Qué información
      necesitas hoy?</h2>
    <div class="relative group">
      <span
        class="material-symbols-outlined absolute left-6 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors text-2xl"
        style="">search</span>
      <input
        class="w-full pl-16 pr-8 py-6 bg-surface-container-low border-none rounded-2xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all text-lg font-body placeholder:text-outline outline-none"
        placeholder="Buscar plagas, cultivos, productos..." type="text">
    </div>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <span class="text-xs text-on-surface-variant font-medium uppercase tracking-wider mr-2 self-center"
        style="">Tendencias:</span>
      <span
        class="bg-surface-container-high px-4 py-1.5 rounded-full text-xs font-semibold cursor-pointer hover:bg-primary-container hover:text-on-primary-container transition-colors"
        style="">Riego por goteo</span>
      <span
        class="bg-surface-container-high px-4 py-1.5 rounded-full text-xs font-semibold cursor-pointer hover:bg-primary-container hover:text-on-primary-container transition-colors"
        style="">Control de roya</span>
      <span
        class="bg-surface-container-high px-4 py-1.5 rounded-full text-xs font-semibold cursor-pointer hover:bg-primary-container hover:text-on-primary-container transition-colors"
        style="">Fertilizantes orgánicos</span>
    </div>
  </section>
  <!-- Categories Grid -->
  <section class="px-6 md:px-24 py-20 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <!-- Category 1 -->
      <div
        class="group bg-surface-container-lowest p-8 rounded-2xl transition-all duration-300 hover:shadow-xl border border-outline-variant/10">
        <div
          class="mb-6 w-14 h-14 bg-surface-container-low rounded-xl flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-on-primary transition-all">
          <span class="material-symbols-outlined text-3xl" style="">bug_report</span>
        </div>
        <h3 class="text-xl font-headline font-bold mb-3" style="">Plagas</h3>
        <p class="text-sm text-on-surface-variant leading-relaxed" style="">Identificación precoz y métodos de control
          biológico y químico certificados.</p>
      </div>
      <!-- Category 2 -->
      <div
        class="group bg-surface-container-lowest p-8 rounded-2xl transition-all duration-300 hover:shadow-xl border border-outline-variant/10">
        <div
          class="mb-6 w-14 h-14 bg-surface-container-low rounded-xl flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-on-primary transition-all">
          <span class="material-symbols-outlined text-3xl" style="">agriculture</span>
        </div>
        <h3 class="text-xl font-headline font-bold mb-3" style="">Cultivos</h3>
        <p class="text-sm text-on-surface-variant leading-relaxed" style="">Fichas técnicas de optimización por zonas
          climáticas y tipos de suelo.</p>
      </div>
      <!-- Category 3 -->
      <div
        class="group bg-surface-container-lowest p-8 rounded-2xl transition-all duration-300 hover:shadow-xl border border-outline-variant/10">
        <div
          class="mb-6 w-14 h-14 bg-surface-container-low rounded-xl flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-on-primary transition-all">
          <span class="material-symbols-outlined text-3xl" style="">shopping_basket</span>
        </div>
        <h3 class="text-xl font-headline font-bold mb-3" style="">Productos</h3>
        <p class="text-sm text-on-surface-variant leading-relaxed" style="">Catálogo de insumos, herramientas y
          tecnología agrícola de vanguardia.</p>
      </div>
      <!-- Category 4 -->
      <div
        class="group bg-surface-container-lowest p-8 rounded-2xl transition-all duration-300 hover:shadow-xl border border-outline-variant/10">
        <div
          class="mb-6 w-14 h-14 bg-surface-container-low rounded-xl flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-on-primary transition-all">
          <span class="material-symbols-outlined text-3xl" style="">forum</span>
        </div>
        <h3 class="text-xl font-headline font-bold mb-3" style="">Foro</h3>
        <p class="text-sm text-on-surface-variant leading-relaxed" style="">Comunidad colaborativa para compartir
          experiencias y resolver dudas reales.</p>
      </div>
    </div>
  </section>
</main>