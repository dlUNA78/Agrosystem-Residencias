<!-- Modal: Añadir/Editar Plaga (Placeholder) -->
<div id="modal-plague" class="fixed inset-0 z-100 hidden items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="modal-plague-backdrop"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-2xl p-6 z-10">
        <div class="flex items-center justify-between border-b border-surface-container pb-4 mb-4">
            <h3 class="text-lg font-extrabold text-[#0F2E2E]">Nueva Plaga</h3>
            <button id="modal-plague-close" class="p-2 rounded-lg hover:bg-surface-container-low text-on-surface-variant transition-colors"><span class="material-symbols-outlined">close</span></button>
        </div>
        <p class="text-sm text-on-surface-variant">Formulario de plaga (pendiente de implementación).</p>
        <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-surface-container">
            <button id="modal-plague-cancel" class="px-6 py-2.5 rounded-lg bg-surface-container-low text-on-surface-variant text-sm font-bold">Cancelar</button>
        </div>
    </div>
</div>

<script>
    (function () {
        // Modal logic (basic)
        const modalPlague = document.getElementById('modal-plague');
        const btnAddPlague = document.getElementById('btn-add-plague');
        const btnAddPlagueCard = document.getElementById('btn-add-plague-card');
        const btnClosePlague = document.getElementById('modal-plague-close');
        const btnCancelPlague = document.getElementById('modal-plague-cancel');

        const openModal = () => modalPlague.classList.replace('hidden', 'flex');
        const closeModal = () => modalPlague.classList.replace('flex', 'hidden');

        if(btnAddPlague) btnAddPlague.addEventListener('click', openModal);
        if(btnAddPlagueCard) btnAddPlagueCard.addEventListener('click', openModal);
        if(btnClosePlague) btnClosePlague.addEventListener('click', closeModal);
        if(btnCancelPlague) btnCancelPlague.addEventListener('click', closeModal);

        // View toggle
        const tableView = document.getElementById('plagues-table-view');
        const gridView = document.getElementById('plagues-grid-view');
        const btnTable = document.getElementById('view-table');
        const btnGrid = document.getElementById('view-grid');

        if (btnTable && btnGrid) {
            btnGrid.classList.add('bg-[#43655c]', 'text-white');
            btnGrid.classList.remove('text-on-surface-variant');
            btnTable.classList.remove('bg-[#43655c]', 'text-white');
            btnTable.classList.add('text-on-surface-variant');

            btnTable.addEventListener('click', function () {
                tableView.style.display = '';
                gridView.style.display = 'none';
                btnTable.classList.add('bg-[#43655c]', 'text-white');
                btnTable.classList.remove('text-on-surface-variant');
                btnGrid.classList.remove('bg-[#43655c]', 'text-white');
                btnGrid.classList.add('text-on-surface-variant');
            });

            btnGrid.addEventListener('click', function () {
                tableView.style.display = 'none';
                gridView.style.display = 'grid';
                btnGrid.classList.add('bg-[#43655c]', 'text-white');
                btnGrid.classList.remove('text-on-surface-variant');
                btnTable.classList.remove('bg-[#43655c]', 'text-white');
                btnTable.classList.add('text-on-surface-variant');
            });
        }
    })();
</script>