<main class="min-h-screen flex flex-col">
    <!-- Content Area -->
    <div class="mt-20 p-12 space-y-10">
        {{!-- Control Bar & Search --}}
        {{> private/search-bar}}

        <!-- Alert Panel -->
        <div class="bg-amber-50 border border-amber-100 p-4 rounded-xl flex items-center justify-between shadow-sm">
            <div class="flex items-center gap-3">
                <div class="bg-amber-100 p-2 rounded-full">
                    <span class="material-symbols-outlined text-amber-700" data-icon="feedback">feedback</span>
                </div>
                <p class="text-amber-900 font-medium text-sm tracking-tight">Tienes <span class="font-bold">24
                        sugerencias</span> de la comunidad pendientes de revisión.</p>
            </div>
            <button
                class="bg-white text-amber-800 border border-amber-200 px-5 py-2 rounded-lg text-xs font-bold hover:bg-amber-100 transition-colors">
                Revisar Sugerencias
            </button>
        </div>

        <!-- TABLE VIEW -->
        <div id="plagues-table-view" style="display:none"
            class="bg-surface-container-lowest rounded-2xl shadow-sm overflow-hidden border border-outline-variant/10">

            <div class="overflow-x-auto">

                <table class="w-full text-left border-collapse">

                    <!-- ENCABEZADOS -->
                    <thead>

                        <tr class="bg-surface-container-low/50">

                            <!-- Imagen -->
                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Imagen
                            </th>

                            <!-- Nombre -->
                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Nombre
                            </th>

                            <!-- Nombre científico -->
                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Nombre Científico
                            </th>

                            <!-- Categoría -->
                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Categoría
                            </th>

                            <!-- Riesgo -->
                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                                Nivel de Riesgo
                            </th>

                            <!-- Región -->
                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Región
                            </th>

                            <!-- Verificado por -->
                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Verificado Por
                            </th>

                            <!-- Fecha de verificación -->
                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Verificado
                            </th>

                            <!-- Estatus -->
                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                                Estatus
                            </th>

                            <!-- Acciones -->
                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-right">
                                Acciones
                            </th>

                        </tr>

                    </thead>

                    <!-- DATOS DE LA BASE DE DATOS -->
                    <tbody>

                        {{#each plagues}}

                        <tr
                            class="border-t border-outline-variant/10 hover:bg-surface-container-low/40 transition-colors">

                            <!-- IMAGEN -->
                            <td class="px-8 py-5">

                                {{#if image_url}}

                                <img src="/{{image_url}}" alt="{{name}}" class="w-16 h-16 rounded-xl object-cover"
                                    onerror="this.src='/images/test/default.png'">

                                {{else}}

                                <div
                                    class="w-16 h-16 rounded-xl bg-surface-container-low flex items-center justify-center">

                                    <span class="material-symbols-outlined text-3xl text-primary/30">
                                        bug_report
                                    </span>

                                </div>

                                {{/if}}

                            </td>


                            <!-- NOMBRE -->
                            <td class="px-8 py-5">

                                <p class="font-extrabold text-[#0F2E2E]">
                                    {{name}}
                                </p>

                            </td>


                            <!-- NOMBRE CIENTÍFICO -->
                            <td class="px-8 py-5">

                                <p class="text-sm text-gray-500 italic">
                                    {{scientific_name}}
                                </p>

                            </td>


                            <!-- CATEGORÍA -->
                            <td class="px-8 py-5">

                                <span class="text-sm text-gray-600">
                                    {{category}}
                                </span>

                            </td>


                            <!-- NIVEL DE RIESGO -->
                            <td class="px-8 py-5 text-center">

                                {{#if risk_level}}

                                <span class="px-3 py-1 rounded-full bg-orange-100 text-orange-700 text-xs font-bold">
                                    {{risk_level}}
                                </span>

                                {{else}}

                                <span class="text-gray-400 text-sm">
                                    Sin especificar
                                </span>

                                {{/if}}

                            </td>


                            <!-- REGIÓN -->
                            <td class="px-8 py-5">

                                <p class="text-sm text-gray-600">
                                    {{region}}
                                </p>

                            </td>


                            <!-- VERIFICADO POR -->
                            <td class="px-8 py-5">

                                {{#if verified_by}}

                                <p class="text-sm text-gray-600">
                                    {{verified_by}}
                                </p>

                                {{else}}

                                <span class="text-gray-400 text-sm">
                                    No verificado
                                </span>

                                {{/if}}

                            </td>


                            <!-- FECHA DE VERIFICACIÓN -->
                            <td class="px-8 py-5">

                                {{#if verified_at}}

                                <p class="text-sm text-gray-600">
                                    {{verified_at}}
                                </p>

                                {{else}}

                                <span class="text-gray-400 text-sm">
                                    Pendiente
                                </span>

                                {{/if}}

                            </td>


                            <!-- ESTATUS -->
                            <td class="px-8 py-5 text-center">

                                {{#if status}}

                                <span class="px-3 py-1 rounded-full bg-green-100 text-green-700 text-xs font-bold">
                                    Activa
                                </span>

                                {{else}}

                                <span class="px-3 py-1 rounded-full bg-red-100 text-red-700 text-xs font-bold">
                                    Inactiva
                                </span>

                                {{/if}}

                            </td>


                            <!-- ACCIONES -->
                            <td class="px-8 py-5">

                                <div class="flex justify-end gap-2">

                                    <!-- EDITAR -->
                                    <button type="button" class="p-2 rounded-lg hover:bg-blue-100 text-blue-600"
                                        title="Editar">

                                        <span class="material-symbols-outlined text-lg">
                                            edit
                                        </span>

                                    </button>

                                    <!-- ELIMINAR -->
                                    <form action="/private/plagues/delete/{{id}}" method="POST"
                                        class="delete-plague-form">

                                        <button type="button"
                                            class="btn-delete-plague p-2 rounded-lg hover:bg-red-100 text-red-600"
                                            title="Eliminar" data-id="{{id}}" data-name="{{name}}">

                                            <span class="material-symbols-outlined text-lg">
                                                delete
                                            </span>

                                        </button>

                                    </form>


                                </div>

                            </td>

                        </tr>

                        {{else}}

                        <!-- CUANDO NO HAY REGISTROS -->
                        <tr>

                            <td colspan="10" class="px-8 py-12 text-center">

                                <span class="material-symbols-outlined text-5xl text-gray-300">
                                    bug_report
                                </span>

                                <p class="mt-3 text-gray-500 font-semibold">
                                    No hay plagas registradas.
                                </p>

                            </td>

                        </tr>

                        {{/each}}

                    </tbody>

                </table>

            </div>


            <!-- PAGINACIÓN -->
            <div
                class="px-8 py-6 bg-surface-container-low/30 border-t border-outline-variant/10 flex items-center justify-between">

                <p class="text-xs font-medium text-on-surface-variant">

                    Mostrando

                    <span class="font-bold text-on-surface">
                        {{plagues.length}}
                    </span>

                    registros

                </p>


                <div class="flex gap-2">

                    <button
                        class="px-5 py-2 rounded-lg bg-surface-container-highest/50 text-on-surface text-xs font-bold hover:bg-surface-container-highest transition-colors flex items-center gap-2">

                        <span class="material-symbols-outlined text-sm">
                            chevron_left
                        </span>

                        Anterior

                    </button>


                    <button
                        class="px-5 py-2 rounded-lg bg-[#43655c] text-white text-xs font-bold hover:bg-[#354f47] transition-colors flex items-center gap-2 shadow-sm">

                        Siguiente

                        <span class="material-symbols-outlined text-sm">
                            chevron_right
                        </span>

                    </button>

                </div>

            </div>

        </div>
        <!-- MODAL -->
        <div id="modal-delete-plague" class="fixed inset-0 z-[100] hidden items-center justify-center p-4">

            <!-- Fondo -->
            <div id="modal-delete-plague-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm">
            </div>

            <!-- Contenido -->
            <div class="relative z-10 w-full max-w-md rounded-2xl bg-white p-6 shadow-2xl">

                <h3 class="text-lg font-bold">
                    ¿Eliminar plaga?
                </h3>

                <p class="mt-3">
                    ¿Seguro que deseas eliminar
                    <strong id="delete-plague-name"></strong>?
                </p>

                <div class="mt-6 flex justify-end gap-3">

                    <!-- CANCELAR -->
                    <button type="button" id="btn-cancel-delete-plague" class="px-4 py-2 rounded-xl border">

                        Cancelar

                    </button>

                    <!-- ESTE ES EL FORMULARIO DEL MODAL -->
                    <form id="delete-plague-form" method="POST">

                        <button type="submit" class="px-4 py-2 rounded-xl bg-red-600 text-white">

                            Eliminar

                        </button>

                    </form>

                </div>

            </div>

        </div>
        <!-- GRID VIEW -->
        <!-- GRID VIEW -->
        <div id="plagues-grid-view" class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 grid">


            {{#each plagues}}

            <!-- TARJETA DE PLAGA -->
            <div
                class="bg-surface-container-lowest rounded-xl border border-outline-variant/10 shadow-sm overflow-hidden group hover:-translate-y-1 transition-all duration-300">


                <!-- IMAGEN -->
                <div class="h-48 bg-surface-container-low overflow-hidden">

                    {{#if image_url}}

                    <img src="/{{image_url}}" alt="{{name}}"
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        onerror="this.src='/images/test/default.png'">

                    {{else}}

                    <div class="w-full h-full flex items-center justify-center">

                        <span class="material-symbols-outlined text-6xl text-primary/20">
                            bug_report
                        </span>

                    </div>

                    {{/if}}

                </div>


                <!-- INFORMACIÓN -->
                <div class="p-5">


                    <!-- NOMBRE Y ESTATUS -->
                    <div class="flex items-start justify-between gap-3">

                        <div>

                            <h3 class="font-extrabold text-[#0F2E2E]">
                                {{name}}
                            </h3>

                            <p class="text-sm text-gray-500 italic">
                                {{scientific_name}}
                            </p>

                        </div>


                        {{#if status}}

                        <span class="px-2 py-1 rounded-full bg-green-100 text-green-700 text-[10px] font-bold">
                            Activa
                        </span>

                        {{else}}

                        <span class="px-2 py-1 rounded-full bg-red-100 text-red-700 text-[10px] font-bold">
                            Inactiva
                        </span>

                        {{/if}}

                    </div>


                    <!-- DATOS PRINCIPALES -->
                    <div class="mt-4 space-y-2 text-sm">


                        <!-- CATEGORÍA -->
                        <p class="text-gray-600">

                            <strong>
                                Categoría:
                            </strong>

                            {{category}}

                        </p>


                        <!-- REGIÓN -->
                        <p class="text-gray-600">

                            <strong>
                                Región:
                            </strong>

                            {{region}}

                        </p>


                        <!-- NIVEL DE RIESGO -->
                        <p class="text-gray-600">
                            <strong> Riesgo:</strong>
                            {{risk_level}}
                        </p>


                        <!-- VERIFICADO POR -->
                        <p class="text-gray-600">
                            <strong>
                                Verificado por:
                            </strong>

                            {{#if verified_by}}

                            {{verified_by}}

                            {{else}}

                            No verificado

                            {{/if}}

                        </p>

                    </div>

                    <!-- ACCIONES -->
                    <div class="flex justify-end gap-2 mt-5 pt-4 border-t border-gray-100">

                        <!-- EDITAR -->
                        <button type="button" class="p-2 rounded-lg hover:bg-blue-100 text-blue-600" title="Editar">

                            <span class="material-symbols-outlined text-lg">
                                edit
                            </span>

                        </button>
                        <!-- ELIMINAR -->
                        <form action="/private/plagues/delete/{{id}}" method="POST" class="delete-plague-form">

                            <button type="button" class="btn-delete-plague p-2 rounded-lg hover:bg-red-100 text-red-600"
                                title="Eliminar" data-id="{{id}}" data-name="{{name}}">

                                <span class="material-symbols-outlined text-lg">
                                    delete
                                </span>

                            </button>

                        </form>

                    </div>

                </div>

            </div>


            {{else}}


            <!-- SIN REGISTROS -->
            <div class="col-span-full text-center py-12">

                <span class="material-symbols-outlined text-5xl text-gray-300">
                    bug_report
                </span>

                <p class="mt-3 text-gray-500 font-semibold">
                    No hay plagas registradas.
                </p>

            </div>

            {{/each}}

            <!-- ADD NEW CARD -->
            <div id="btn-add-plague-card"
                class="bg-surface-container-lowest rounded-xl border-2 border-dashed border-primary/20 shadow-sm overflow-hidden group hover:-translate-y-1 transition-all duration-300 flex items-center justify-center min-h-[220px] cursor-pointer">
                <div class="text-center p-6">
                    <span
                        class="material-symbols-outlined text-3xl text-primary/30 mb-2 group-hover:text-primary/50 transition-colors">
                        bug_report
                    </span>
                    <p class="text-sm font-bold text-on-surface-variant group-hover:text-primary transition-colors">
                        Añadir plaga
                    </p>

                </div>

            </div>

        </div>
    </div>
</main>

<!-- Modal: Añadir/Editar Plaga (Placeholder) -->
<div id="modal-plague" class="fixed inset-0 z-100 hidden items-center justify-center p-4">
    <div id="modal-plague-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>

    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-4xl max-h-[90vh] overflow-y-auto z-10">
        <form id="plague-form" action="/private/plagues/create" method="POST" enctype="multipart/form-data">

            <div class="flex items-center justify-between border-b px-6 py-4">
                <h3 id="modal-plague-title" class="text-xl font-extrabold text-[#0F2E2E]">Nueva Plaga</h3>
                <button type="button" id="modal-plague-close" class="p-2 rounded-lg hover:bg-gray-100">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label class="block font-bold mb-2">Nombre</label>
                    <input type="text" name="name" class="w-full border rounded-lg p-3" required>
                </div>

                <div>
                    <label class="block font-bold mb-2">Nombre científico</label>
                    <input type="text" name="scientific_name" class="w-full border rounded-lg p-3" required>
                </div>

                <div>
                    <label class="block font-bold mb-2">Categoría</label>
                    <select name="category" class="w-full border rounded-lg p-3">
                        <option value="">Seleccione...</option>
                        <option>Insecto</option>
                        <option>Hongo</option>
                        <option>Bacteria</option>
                        <option>Virus</option>
                        <option>Ácaro</option>
                    </select>
                </div>

                <div>
                    <label class="block font-bold mb-2">Región</label>
                    <input type="text" name="region" class="w-full border rounded-lg p-3">
                </div>

                <div>
                    <label class="block font-bold mb-2">Nivel de Riesgo</label>
                    <select name="risk_level" class="w-full border rounded-lg p-3">
                        <option>Bajo</option>
                        <option>Medio</option>
                        <option>Alto</option>
                        <option>Crítico</option>
                    </select>
                </div>

                <div>
                    <label class="block font-bold mb-2">Estado</label>
                    <select name="status" class="w-full border rounded-lg p-3">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="md:col-span-2">
                    <label class="block font-bold mb-2">Descripción</label>
                    <textarea name="description" rows="3" class="w-full border rounded-lg p-3"></textarea>
                </div>

                <div class="md:col-span-2">
                    <label class="block font-bold mb-2">Síntomas</label>
                    <textarea name="symptoms" rows="3" class="w-full border rounded-lg p-3"></textarea>
                </div>

                <div>
                    <label class="block font-bold mb-2">Métodos de Control</label>
                    <textarea name="control_methods" rows="4" class="w-full border rounded-lg p-3"></textarea>
                </div>

                <div>
                    <label class="block font-bold mb-2">Control Biológico</label>
                    <textarea name="biological_control" rows="4" class="w-full border rounded-lg p-3"></textarea>
                </div>

                <div class="md:col-span-2">
                    <label class="block font-bold mb-2">Imagen</label>
                    <div class="flex items-center gap-5">
                        <img id="plague-preview" class="hidden w-36 h-36 rounded-xl border object-cover">
                        <div class="flex-1">
                            <input id="plague-image" type="file" name="image" accept="image/*"
                                class="w-full border rounded-lg p-3">
                            <p class="text-xs text-gray-500 mt-2">JPG, PNG o WEBP.</p>
                        </div>
                    </div>
                </div>

            </div>

            <div class="flex justify-end gap-3 border-t px-6 py-4">
                <button type="button" id="modal-plague-cancel"
                    class="px-6 py-2.5 rounded-lg bg-gray-200 font-bold hover:bg-gray-300">
                    Cancelar
                </button>

                <button type="submit" id="btn-save-plague"
                    class="px-6 py-2.5 rounded-lg bg-[#43655c] text-white font-bold hover:bg-[#355049]">
                    Guardar Plaga
                </button>
            </div>

        </form>
    </div>
</div>

<script>
    (() => {

        const modal = document.getElementById("modal-plague");
        const form = document.getElementById("plague-form");

        const btnAdd = document.getElementById("btn-add-plague");
        const btnAddCard = document.getElementById("btn-add-plague-card");

        const btnClose = document.getElementById("modal-plague-close");
        const btnCancel = document.getElementById("modal-plague-cancel");
        const backdrop = document.getElementById("modal-plague-backdrop");

        const title = document.getElementById("modal-plague-title");

        const imageInput = document.getElementById("plague-image");
        const imagePreview = document.getElementById("plague-preview");

        // BUSCADOR EN TIEMPO REAL
        const searchInput = document.getElementById("plague-search");

        if (searchInput) {

            searchInput.addEventListener("input", () => {

                const search = searchInput.value.toLowerCase().trim();

                // FILAS DE LA TABLA
                const rows = document.querySelectorAll(
                    "#plagues-table-view tbody tr"
                );

                rows.forEach(row => {

                    const text = row.textContent.toLowerCase();

                    row.style.display =
                        text.includes(search) ? "" : "none";

                });

                // TARJETAS DEL GRID
                const cards = document.querySelectorAll(
                    "#plagues-grid-view > div:not(#btn-add-plague-card)"
                );

                cards.forEach(card => {

                    const text = card.textContent.toLowerCase();

                    card.style.display =
                        text.includes(search) ? "" : "none";

                });

            });

        }

        function openModal() {

            form.reset();

            title.textContent = "Nueva Plaga";

            form.action = "/private/plagues/create";

            imagePreview.src = "";
            imagePreview.classList.add("hidden");

            modal.classList.remove("hidden");
            modal.classList.add("flex");
        }

        function closeModal() {
            modal.classList.remove("flex");
            modal.classList.add("hidden");
        }

        if (btnAdd) btnAdd.addEventListener("click", openModal);
        if (btnAddCard) btnAddCard.addEventListener("click", openModal);

        btnClose.addEventListener("click", closeModal);
        btnCancel.addEventListener("click", closeModal);
        backdrop.addEventListener("click", closeModal);

        imageInput.addEventListener("change", function () {

            const file = this.files[0];

            if (!file) {
                imagePreview.src = "";
                imagePreview.classList.add("hidden");
                return;
            }

            imagePreview.src = URL.createObjectURL(file);
            imagePreview.classList.remove("hidden");

        });

        // CAMBIO DE VISTA

        const tableView = document.getElementById("plagues-table-view");
        const gridView = document.getElementById("plagues-grid-view");

        const btnTable = document.getElementById("view-table");
        const btnGrid = document.getElementById("view-grid");

        if (btnTable && btnGrid) {

            btnGrid.classList.add("bg-[#43655c]", "text-white");
            btnGrid.classList.remove("text-on-surface-variant");

            btnTable.classList.remove("bg-[#43655c]", "text-white");
            btnTable.classList.add("text-on-surface-variant");

            btnTable.addEventListener("click", () => {

                tableView.style.display = "";
                gridView.style.display = "none";

                btnTable.classList.add("bg-[#43655c]", "text-white");
                btnTable.classList.remove("text-on-surface-variant");

                btnGrid.classList.remove("bg-[#43655c]", "text-white");
                btnGrid.classList.add("text-on-surface-variant");

            });

            btnGrid.addEventListener("click", () => {

                tableView.style.display = "none";
                gridView.style.display = "grid";

                btnGrid.classList.add("bg-[#43655c]", "text-white");
                btnGrid.classList.remove("text-on-surface-variant");

                btnTable.classList.remove("bg-[#43655c]", "text-white");
                btnTable.classList.add("text-on-surface-variant");

            });

        }

    })();
</script>

<script>
    document.addEventListener("DOMContentLoaded", () => {

        const modal = document.getElementById("modal-delete-plague");
        const backdrop = document.getElementById("modal-delete-plague-backdrop");

        const deleteForm = document.getElementById("delete-plague-form");
        const deleteName = document.getElementById("delete-plague-name");

        const cancelButton = document.getElementById(
            "btn-cancel-delete-plague"
        );

        document.querySelectorAll(".btn-delete-plague").forEach(button => {

            button.addEventListener("click", () => {

                const id = button.dataset.id;
                const name = button.dataset.name;

                deleteName.textContent = name;

                deleteForm.action =
                    `/private/plagues/delete/${id}`;

                modal.classList.remove("hidden");
                modal.classList.add("flex");

            });

        });

        const closeModal = () => {
            modal.classList.add("hidden");
            modal.classList.remove("flex");
        };

        cancelButton.addEventListener("click", closeModal);
        backdrop.addEventListener("click", closeModal);

    });
</script>