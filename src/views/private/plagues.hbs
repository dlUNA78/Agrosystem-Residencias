<main class="min-h-screen flex flex-col">
    <!-- Content Area -->
    <div class="mt-20 p-12 space-y-10">
        {{!-- Control Bar & Search --}}
        {{> private/search-bar}}

        <!-- Alert Panel -->
        <div class="bg-amber-50 border border-amber-100 p-4 rounded-xl flex items-center justify-between shadow-sm">
            <div class="flex items-center gap-3">
                <div class="bg-amber-100 p-2 rounded-full">
                    <span class="material-symbols-outlined text-amber-700" data-icon="feedback">feedback</span>
                </div>
                <p class="text-amber-900 font-medium text-sm tracking-tight">Tienes <span class="font-bold">24
                        sugerencias</span> de la comunidad pendientes de revisión.</p>
            </div>
            <button
                class="bg-white text-amber-800 border border-amber-200 px-5 py-2 rounded-lg text-xs font-bold hover:bg-amber-100 transition-colors">
                Revisar Sugerencias
            </button>
        </div>
        <!-- Data Grid -->
        <div class="bg-surface-container-lowest rounded-2xl shadow-sm overflow-hidden border border-outline-variant/10">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container-low/50">
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                            Imagen</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                            Detalles de la Plaga</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                            Cultivos Afectados</th>
                        <th
                            class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                            Nivel de Riesgo</th>
                        <th
                            class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                            Estatus</th>
                        <th
                            class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-right">
                            Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-surface-container">
                    <!-- Row 1 -->
                    <tr class="hover:bg-surface/50 transition-colors">
                        <td class="px-8 py-6">
                            <img alt="Gusano Cogollero"
                                class="w-20 h-14 rounded-lg object-cover bg-surface-container shadow-sm"
                                data-alt="macro photograph of a fall armyworm larvae on a green maize leaf with high detail and soft natural lighting"
                                src="/images/test/gusano_cogollero.png" />
                        </td>
                        <td class="px-8 py-6">
                            <p class="font-bold text-on-surface text-sm">Gusano Cogollero</p>
                            <p class="text-xs italic text-on-surface-variant">Spodoptera frugiperda</p>
                        </td>
                        <td class="px-8 py-6">
                            <div class="flex flex-wrap gap-2">
                                <span
                                    class="px-3 py-1 bg-primary-container text-on-primary-container rounded-full text-[10px] font-bold uppercase tracking-tight">Maíz</span>
                                <span
                                    class="px-3 py-1 bg-primary-container text-on-primary-container rounded-full text-[10px] font-bold uppercase tracking-tight">Sorgo</span>
                            </div>
                        </td>
                        <td class="px-8 py-6 text-center">
                            <span
                                class="px-4 py-1.5 bg-error/10 text-error rounded-full text-[10px] font-black uppercase">Crítica</span>
                        </td>
                        <td class="px-8 py-6 text-center">
                            <div
                                class="flex items-center justify-center gap-1.5 text-emerald-600 bg-emerald-50 px-3 py-1.5 rounded-full border border-emerald-100 mx-auto w-fit">
                                <span class="material-symbols-outlined text-sm" data-icon="check_circle"
                                    data-weight="fill" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                                <span class="text-[10px] font-black uppercase">Aprobado</span>
                            </div>
                        </td>
                        <td class="px-8 py-6">
                            <div class="flex justify-end gap-3 text-on-surface-variant">
                                <a href="#" class="hover:text-primary transition-colors"><span
                                        class="material-symbols-outlined"
                                        data-icon="visibility">visibility</span></a>
                                <button class="hover:text-primary transition-colors"><span
                                        class="material-symbols-outlined" data-icon="edit">edit</span></button>
                                <button class="hover:text-error transition-colors"><span
                                        class="material-symbols-outlined" data-icon="delete">delete</span></button>
                            </div>
                        </td>
                    </tr>
                    <!-- Row 2 -->
                    <tr class="hover:bg-surface/50 transition-colors">
                        <td class="px-8 py-6">
                            <img alt="Pulgón Verde"
                                class="w-20 h-14 rounded-lg object-cover bg-surface-container shadow-sm"
                                data-alt="detailed close-up of a fruit fly with colorful wings perched on an orange peel with scientific studio lighting"
                                src="/images/test/pulgon_verde.png" />
                        </td>
                        <td class="px-8 py-6">
                            <p class="font-bold text-on-surface text-sm">Pulgón Verde</p>
                            <p class="text-xs italic text-on-surface-variant">Schizaphis graminum</p>
                        </td>
                        <td class="px-8 py-6">
                            <div class="flex flex-wrap gap-2">
                                <span
                                    class="px-3 py-1 bg-primary-container text-on-primary-container rounded-full text-[10px] font-bold uppercase tracking-tight">Mango</span>
                                <span
                                    class="px-3 py-1 bg-primary-container text-on-primary-container rounded-full text-[10px] font-bold uppercase tracking-tight">Naranja</span>
                            </div>
                        </td>
                        <td class="px-8 py-6 text-center">
                            <span
                                class="px-4 py-1.5 bg-amber-400/10 text-amber-700 rounded-full text-[10px] font-black uppercase">Media</span>
                        </td>
                        <td class="px-8 py-6 text-center">
                            <div
                                class="flex items-center justify-center gap-1.5 text-emerald-600 bg-emerald-50 px-3 py-1.5 rounded-full border border-emerald-100 mx-auto w-fit">
                                <span class="material-symbols-outlined text-sm" data-icon="check_circle"
                                    data-weight="fill" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                                <span class="text-[10px] font-black uppercase">Aprobado</span>
                            </div>
                        </td>
                        <td class="px-8 py-6">
                            <div class="flex justify-end gap-3 text-on-surface-variant">
                                <a href="/private/plagues/pulgon-verde" class="hover:text-primary transition-colors"><span
                                        class="material-symbols-outlined"
                                        data-icon="visibility">visibility</span></a>
                                <button class="hover:text-primary transition-colors"><span
                                        class="material-symbols-outlined" data-icon="edit">edit</span></button>
                                <button class="hover:text-error transition-colors"><span
                                        class="material-symbols-outlined" data-icon="delete">delete</span></button>
                            </div>
                        </td>
                    </tr>
                    <!-- Row 3 Pending -->
                    <tr class="hover:bg-surface/50 transition-colors bg-surface-container-low/20">
                        <td class="px-8 py-6">
                            <img alt="Mancha Negra"
                                class="w-20 h-14 rounded-lg object-cover bg-surface-container shadow-sm grayscale-[0.5]"
                                data-alt="botanical close-up of citrus black spot disease on a lemon leaf showing distinct dark necrotic lesions"
                                src="/images/test/mancha_negra.png" />
                        </td>
                        <td class="px-8 py-6">
                            <p class="font-bold text-on-surface text-sm">Mancha Negra</p>
                            <p class="text-xs italic text-on-surface-variant">Guignardia citricarpa</p>
                        </td>
                        <td class="px-8 py-6">
                            <div class="flex flex-wrap gap-2">
                                <span
                                    class="px-3 py-1 bg-primary-container text-on-primary-container rounded-full text-[10px] font-bold uppercase tracking-tight">Limón</span>
                            </div>
                        </td>
                        <td class="px-8 py-6 text-center">
                            <span
                                class="px-4 py-1.5 bg-amber-400/10 text-amber-700 rounded-full text-[10px] font-black uppercase">Media</span>
                        </td>
                        <td class="px-8 py-6 text-center">
                            <div
                                class="flex items-center justify-center gap-1.5 text-orange-600 bg-orange-50 px-3 py-1.5 rounded-full border border-orange-100 mx-auto w-fit">
                                <span class="material-symbols-outlined text-sm" data-icon="schedule">schedule</span>
                                <span class="text-[10px] font-black uppercase">Pendiente</span>
                            </div>
                        </td>
                        <td class="px-8 py-6">
                            <div class="flex justify-end gap-3 text-on-surface-variant">
                                <button class="hover:text-primary transition-colors"><span
                                        class="material-symbols-outlined"
                                        data-icon="visibility">visibility</span></button>
                                <button class="hover:text-primary transition-colors"><span
                                        class="material-symbols-outlined" data-icon="edit">edit</span></button>
                                <button class="hover:text-error transition-colors"><span
                                        class="material-symbols-outlined" data-icon="delete">delete</span></button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
            <!-- Pagination -->
            <div
                class="px-8 py-6 bg-surface-container-low/30 border-t border-outline-variant/10 flex items-center justify-between">
                <p class="text-xs font-medium text-on-surface-variant">
                    Mostrando <span class="font-bold text-on-surface">1 a 10</span> de <span
                        class="font-bold text-on-surface">156</span> registros
                </p>
                <div class="flex gap-2">
                    <button
                        class="px-5 py-2 rounded-lg bg-surface-container-highest/50 text-on-surface text-xs font-bold hover:bg-surface-container-highest transition-colors flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm" data-icon="chevron_left">chevron_left</span>
                        Anterior
                    </button>
                    <button
                        class="px-5 py-2 rounded-lg bg-primary text-white text-xs font-bold hover:bg-primary-dim transition-colors flex items-center gap-2 shadow-sm shadow-primary/20">
                        Siguiente
                        <span class="material-symbols-outlined text-sm" data-icon="chevron_right">chevron_right</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</main>