<main class="min-h-screen flex flex-col">
    <div class="mt-20 p-6 md:p-12 space-y-8">

        <!-- Page Header -->
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
                <h2 class="text-2xl font-extrabold text-[#0F2E2E] tracking-tight">Catálogo de Productos</h2>
                <p class="text-sm text-on-surface-variant mt-1">Gestión de agroquímicos y formulaciones del repositorio
                    INIFAP</p>
            </div>
        </div>


        <!-- KPI Strip -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div
                class="bg-surface-container-lowest rounded-xl p-5 border border-outline-variant/10 shadow-sm flex items-center gap-4">
                <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-[#43655c] text-xl">inventory_2</span>
                </div>
                <div>
                    <p class="text-2xl font-extrabold text-[#0F2E2E] leading-none">800</p>
                    <p class="text-[10px] uppercase tracking-widest text-on-surface-variant font-bold mt-0.5">Total</p>
                </div>
            </div>
            <div
                class="bg-surface-container-lowest rounded-xl p-5 border border-outline-variant/10 shadow-sm flex items-center gap-4">
                <div class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-emerald-600 text-xl">verified</span>
                </div>
                <div>
                    <p class="text-2xl font-extrabold text-[#0F2E2E] leading-none">612</p>
                    <p class="text-[10px] uppercase tracking-widest text-on-surface-variant font-bold mt-0.5">Aprobados
                    </p>
                </div>
            </div>
            <div
                class="bg-surface-container-lowest rounded-xl p-5 border border-outline-variant/10 shadow-sm flex items-center gap-4">
                <div class="w-10 h-10 rounded-lg bg-amber-50 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-amber-600 text-xl">schedule</span>
                </div>
                <div>
                    <p class="text-2xl font-extrabold text-[#0F2E2E] leading-none">147</p>
                    <p class="text-[10px] uppercase tracking-widest text-on-surface-variant font-bold mt-0.5">Pendientes
                    </p>
                </div>
            </div>
            <div
                class="bg-surface-container-lowest rounded-xl p-5 border border-outline-variant/10 shadow-sm flex items-center gap-4">
                <div class="w-10 h-10 rounded-lg bg-red-50 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-red-500 text-xl">block</span>
                </div>
                <div>
                    <p class="text-2xl font-extrabold text-[#0F2E2E] leading-none">41</p>
                    <p class="text-[10px] uppercase tracking-widest text-on-surface-variant font-bold mt-0.5">
                        Restringidos</p>
                </div>
            </div>
        </div>

        {{!-- Control Bar & Search --}}
        {{> private/search-bar}}



        <!-- Alert Panel -->
        <div
            class="bg-amber-50 border border-amber-100 p-4 rounded-xl flex flex-wrap items-center justify-between gap-3 shadow-sm">
            <div class="flex items-center gap-3">
                <div class="bg-amber-100 p-2 rounded-full">
                    <span class="material-symbols-outlined text-amber-700">feedback</span>
                </div>
                <p class="text-amber-900 font-medium text-sm tracking-tight">
                    Tienes <span class="font-bold"></span> con registro próximo a vencer en los próximos 90
                    días.
                </p>
            </div>
            <button
                class="bg-white text-amber-800 border border-amber-200 px-5 py-2 rounded-lg text-xs font-bold hover:bg-amber-100 transition-colors">
                Ver registros
            </button>
        </div>

        <!-- TABLE VIEW -->
        <div id="products-table-view" style="display:none"
            class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/10 overflow-x-auto">

            <div class="min-w-[1200px]">
                <table class="w-full text-left border-collapse min-w-[1200px]">

                    <thead>
                        <tr class="bg-surface-container-low/50">

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Imagen
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Producto
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Categoría
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Ingrediente activo
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Registro
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Fabricante
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Cultivos
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                                Validación
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                                Estatus
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-right">
                                Acciones
                            </th>

                        </tr>
                    </thead>

                    <tbody>

                        {{#each products}}
                        <tr class="product-item" data-name="{{name}}" data-category="{{category}}"
                            data-manufacturer="{{manufacturer}}" data-active="{{active_ingredient}}"
                            data-registration="{{registration_code}}" data-status="{{validation_status}}">

                            <td class="px-6 py-4">
                                <img src="/{{image_url}}" alt="{{name}}" class="w-14 h-14 rounded-lg object-cover"
                                    onerror="this.src='/images/test/default.png'">
                            </td>

                            <td class="px-6 py-4 font-semibold">
                                {{name}}
                            </td>

                            <td class="px-6 py-4">
                                {{category}}
                            </td>

                            <td class="px-6 py-4">
                                {{active_ingredient}}
                            </td>

                            <td class="px-6 py-4">
                                {{registration_code}}
                            </td>

                            <td class="px-6 py-4">
                                {{manufacturer}}
                            </td>

                            <td class="px-6 py-4">
                                {{target_crops}}
                            </td>

                            <td class="px-6 py-4 text-center">
                                {{validation_status}}
                            </td>

                            <td class="px-6 py-4 text-center">
                                {{#if status}}
                                <span class="text-green-600 font-semibold">Activo</span>
                                {{else}}
                                <span class="text-red-600 font-semibold">Inactivo</span>
                                {{/if}}
                            </td>

                            <td class="px-6 py-4 text-right whitespace-nowrap">

                                <button type="button" onclick="window.location.href='/private/products/edit/{{id}}'"
                                    class="inline-flex items-center gap-1 text-blue-600 hover:underline">
                                    ✏️ Editar
                                </button>
                                <form id="delete-form-{{id}}" action="/private/products/delete/{{id}}" method="POST"
                                    style="display:inline;">

                                    <button type="button" data-delete-btn data-id="{{id}}" data-name="{{name}}"
                                        class="inline-flex items-center gap-1 text-red-600 hover:underline">
                                        🗑 Eliminar
                                    </button>

                                </form>

                            </td>

                        </tr>
                        {{/each}}
                    </tbody>

                </table>
            </div>

            <!-- Pagination -->
            <div
                class="px-6 py-5 bg-surface-container-low/30 border-t border-outline-variant/10 flex flex-wrap items-center justify-between gap-3">
                <p class="text-xs font-medium text-on-surface-variant">
                    Mostrando <span class="font-bold text-on-surface">1 a 6</span> de <span
                        class="font-bold text-on-surface">800</span> productos
                </p>
                <div class="flex gap-2">
                    <button
                        class="px-5 py-2 rounded-lg bg-surface-container-highest/50 text-on-surface text-xs font-bold hover:bg-surface-container-highest transition-colors flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">chevron_left</span>
                        Anterior
                    </button>
                    <button
                        class="px-5 py-2 rounded-lg bg-[#43655c] text-white text-xs font-bold hover:bg-[#354f47] transition-colors flex items-center gap-2 shadow-sm">
                        Siguiente
                        <span class="material-symbols-outlined text-sm">chevron_right</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- GRID VIEW -->
        <div id="products-grid-view" class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 grid">

            {{#each products}}
            <!-- para buscar-->
            <div class="product-item" data-name="{{name}}" data-category="{{category}}"
                data-manufacturer="{{manufacturer}}" data-active="{{active_ingredient}}"
                data-registration="{{registration_code}}" data-status="{{validation_status}}">

                <!-- IMAGE -->
                <div class="relative h-40 overflow-hidden">
                    <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        src="/{{image_url}}" alt="{{name}}" onerror="this.src='/images/test/default.png'" />

                    <div class="absolute top-2 left-2">
                        <span
                            class="inline-flex items-center gap-0.5 px-2 py-1 bg-[#43655c] text-white rounded text-[9px] font-black uppercase shadow-lg">
                            <span class="material-symbols-outlined text-xs leading-none"
                                style="font-variation-settings:'FILL' 1">verified</span>
                            {{validation_status}}
                        </span>
                    </div>
                </div>

                <!-- CONTENT -->
                <div class="p-4">

                    <span class="text-[9px] font-black uppercase tracking-widest
                {{#if (eq category " Insecticida")}}text-orange-600{{/if}} {{#if (eq category "Fungicida"
                        )}}text-green-600{{/if}} {{#if (eq category "Herbicida" )}}text-blue-600{{/if}}">
                        {{category}}
                    </span>

                    <h3 class="font-bold text-on-surface text-sm mt-1">
                        {{name}}
                    </h3>

                    <p class="text-xs italic text-on-surface-variant">
                        {{active_ingredient}} · {{registration_code}}
                    </p>

                    <div class="mt-3 pt-3 border-t border-surface-container flex justify-between items-center">

                        <span class="text-[10px] text-on-surface-variant">
                            {{manufacturer}}
                        </span>

                        <!-- ACTIONS -->
                        <div class="flex gap-3">

                            <button type="button" onclick="window.location.href='/private/products/edit/{{id}}'"
                                class="text-blue-600 hover:underline">
                                ✏️ Editar
                            </button>

                            <button type="button" data-delete-btn data-id="{{id}}" data-name="{{name}}"
                                class="text-red-600 hover:underline">
                                🗑 Eliminar
                            </button>

                        </div>

                    </div>
                </div>
            </div>

            {{/each}}

            <!-- ADD CARD -->
            <div id="btn-add-product-card"
                class="bg-surface-container-lowest rounded-xl border-2 border-dashed border-primary/20 shadow-sm overflow-hidden group hover:-translate-y-1 transition-all duration-300 flex items-center justify-center min-h-[220px] cursor-pointer">

                <div class="text-center p-6">
                    <span
                        class="material-symbols-outlined text-3xl text-primary/30 mb-2 group-hover:text-primary/50 transition-colors">
                        add_circle
                    </span>

                    <p class="text-sm font-bold text-on-surface-variant group-hover:text-primary transition-colors">
                        Añadir producto
                    </p>
                </div>
            </div>

        </div>

    </div>
</main>

<!-- Modal: Añadir/Editar Producto -->
<div id="modal-product" class="fixed inset-0 z-100 hidden items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="modal-product-backdrop"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-y-auto z-10">
        <div class="flex items-center justify-between p-6 border-b border-surface-container">
            <div>
                <h3 class="text-lg font-extrabold text-[#0F2E2E]">Nuevo Producto Agroquímico</h3>
                <p class="text-xs text-on-surface-variant mt-0.5">Completa la información para registrar el producto en
                    el catálogo INIFAP</p>
            </div>
            <button id="modal-product-close"
                class="p-2 rounded-lg hover:bg-surface-container-low text-on-surface-variant transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form action="/private/products/create" method="POST" enctype="multipart/form-data" class="p-6 space-y-5">

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                <!-- Nombre -->
                <div class="sm:col-span-2">
                    <label class="block text-xs font-bold uppercase tracking-widest mb-2">
                        Nombre Comercial *
                    </label>

                    <input type="text" name="name" required placeholder="Ej. Glyphomax Pro 480"
                        class="w-full bg-surface-container-low rounded-lg py-3 px-4 text-sm border-none focus:ring-2 focus:ring-primary/20">
                </div>

                <!-- Imagen -->
                <div class="sm:col-span-2">
                    <label class="block text-xs font-bold uppercase tracking-widest mb-2">
                        Imagen del Producto *
                    </label>

                    <input type="file" name="image" accept="image/*" required
                        class="w-full bg-surface-container-low rounded-lg py-3 px-4 text-sm border-none">

                    <p class="text-xs text-gray-500 mt-2">
                        Formatos permitidos: JPG, PNG, JPEG, WEBP
                    </p>
                </div>

                <!-- Categoría -->
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest mb-2">
                        Categoría *
                    </label>

                    <select name="category" required
                        class="w-full bg-surface-container-low rounded-lg py-3 px-4 text-sm border-none">

                        <option value="">Seleccionar...</option>
                        <option value="Herbicida">Herbicida</option>
                        <option value="Insecticida">Insecticida</option>
                        <option value="Fungicida">Fungicida</option>
                        <option value="Fertilizante">Fertilizante</option>
                        <option value="Acaricida">Acaricida</option>
                        <option value="Bactericida">Bactericida</option>
                        <option value="Coadyuvante">Coadyuvante</option>

                    </select>
                </div>

                <!-- Fabricante -->
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest mb-2">
                        Fabricante *
                    </label>

                    <input type="text" name="manufacturer" required placeholder="Ej. Bayer"
                        class="w-full bg-surface-container-low rounded-lg py-3 px-4 text-sm border-none">
                </div>

                <!-- Principio Activo -->
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest mb-2">
                        Principio Activo *
                    </label>

                    <input type="text" name="active_ingredient" required placeholder="Ej. Glifosato 48%"
                        class="w-full bg-surface-container-low rounded-lg py-3 px-4 text-sm border-none">
                </div>

                <!-- Registro -->
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest mb-2">
                        Registro COFEPRIS *
                    </label>

                    <input type="text" name="registration_code" required placeholder="Ej. RSCO-1234"
                        class="w-full bg-surface-container-low rounded-lg py-3 px-4 text-sm border-none">
                </div>

                <!-- Validación -->
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest mb-2">
                        Estado de Validación
                    </label>

                    <select name="validation_status"
                        class="w-full bg-surface-container-low rounded-lg py-3 px-4 text-sm border-none">

                        <option value="En revisión">En revisión</option>
                        <option value="Validado">Validado</option>
                        <option value="Restringido">Restringido</option>

                    </select>
                </div>

                <!-- Fecha -->
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest mb-2">
                        Fecha de Vencimiento
                    </label>

                    <input type="date" name="expiration_date"
                        class="w-full bg-surface-container-low rounded-lg py-3 px-4 text-sm border-none">
                </div>

                <!-- Cultivos -->
                <div class="sm:col-span-2">
                    <label class="block text-xs font-bold uppercase tracking-widest mb-2">
                        Cultivos Objetivo
                    </label>

                    <input type="text" name="target_crops" placeholder="Ej. Maíz, Trigo, Sorgo"
                        class="w-full bg-surface-container-low rounded-lg py-3 px-4 text-sm border-none">
                </div>

                <!-- Descripción -->
                <div class="sm:col-span-2">
                    <label class="block text-xs font-bold uppercase tracking-widest mb-2">
                        Descripción Técnica
                    </label>

                    <textarea name="description" rows="4" placeholder="Descripción del producto..."
                        class="w-full bg-surface-container-low rounded-lg py-3 px-4 text-sm border-none resize-none"></textarea>
                </div>

                <!-- Estado -->
                <div class="sm:col-span-2">
                    <label class="flex items-center gap-3">

                        <input type="checkbox" name="status" value="true" checked>

                        <span class="text-sm font-semibold">
                            Producto Activo
                        </span>

                    </label>
                </div>

            </div>

            <div class="flex justify-end gap-3 pt-4 border-t">

                <button type="button" id="modal-product-cancel"
                    class="px-6 py-3 rounded-lg bg-gray-200 hover:bg-gray-300">
                    Cancelar
                </button>
                <button type="submit" class="px-6 py-3 rounded-lg bg-[#43655c] hover:bg-[#36514a] text-white font-bold">
                    Guardar Producto
                </button>

            </div>

        </form>
    </div>
</div>

<!-- MODAL CONFIRM DELETE -->
<div id="delete-modal" class="fixed inset-0 hidden items-center justify-center bg-black/50 z-50">

    <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-md">

        <h2 class="text-lg font-bold text-[#0F2E2E]">Confirmar eliminación</h2>

        <p class="text-sm text-gray-600 mt-2">
            ¿Seguro que deseas eliminar <span id="delete-product-name" class="font-semibold"></span>?
        </p>

        <div class="flex justify-end gap-3 mt-6">

            <button id="cancel-delete" class="px-4 py-2 rounded-lg bg-gray-200 hover:bg-gray-300">
                Cancelar
            </button>

            <button id="confirm-delete" class="px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700">
                Eliminar
            </button>

        </div>

    </div>

</div>

<script>
    (function () {
        // Modal
        const modal = document.getElementById('modal-product');
        const openBtn = document.getElementById('btn-add-product');
        const openBtnCard = document.getElementById('btn-add-product-card');
        const closeBtn = document.getElementById('modal-product-close');
        const cancelBtn = document.getElementById('modal-product-cancel');
        const backdrop = document.getElementById('modal-product-backdrop');

        function openModal() { modal.classList.remove('hidden'); modal.classList.add('flex'); }
        function closeModal() { modal.classList.add('hidden'); modal.classList.remove('flex'); }

        if (openBtn) openBtn.addEventListener('click', openModal);
        if (openBtnCard) openBtnCard.addEventListener('click', openModal);
        if (closeBtn) closeBtn.addEventListener('click', closeModal);
        if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
        if (backdrop) backdrop.addEventListener('click', closeModal);

        // View toggle
        const tableView = document.getElementById('products-table-view');
        const gridView = document.getElementById('products-grid-view');
        const btnTable = document.getElementById('view-table');
        const btnGrid = document.getElementById('view-grid');

        if (btnTable && btnGrid) {
            btnGrid.classList.add('bg-[#43655c]', 'text-white');
            btnGrid.classList.remove('text-on-surface-variant');
            btnTable.classList.remove('bg-[#43655c]', 'text-white');
            btnTable.classList.add('text-on-surface-variant');

            btnTable.addEventListener('click', function () {
                tableView.style.display = '';
                gridView.style.display = 'none';
                btnTable.classList.add('bg-[#43655c]', 'text-white');
                btnTable.classList.remove('text-on-surface-variant');
                btnGrid.classList.remove('bg-[#43655c]', 'text-white');
                btnGrid.classList.add('text-on-surface-variant');
            });

            btnGrid.addEventListener('click', function () {
                tableView.style.display = 'none';
                gridView.style.display = 'grid';
                btnGrid.classList.add('bg-[#43655c]', 'text-white');
                btnGrid.classList.remove('text-on-surface-variant');
                btnTable.classList.remove('bg-[#43655c]', 'text-white');
                btnTable.classList.add('text-on-surface-variant');
            });
        }
    })();
</script>

<script>
    window.addEventListener('DOMContentLoaded', () => {

        const modal = document.getElementById('delete-modal');
        const nameSpan = document.getElementById('delete-product-name');
        const cancelBtn = document.getElementById('cancel-delete');
        const confirmBtn = document.getElementById('confirm-delete');

        let formToDelete = null;

        document.querySelectorAll('[data-delete-btn]').forEach(btn => {
            btn.addEventListener('click', function () {
                const id = this.dataset.id;
                const name = this.dataset.name;

                formToDelete = document.getElementById('delete-form-' + id);

                nameSpan.textContent = name;

                modal.classList.remove('hidden');
                modal.classList.add('flex');
            });
        });

        cancelBtn.addEventListener('click', () => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            formToDelete = null;
        });

        confirmBtn.addEventListener('click', () => {
            if (formToDelete) formToDelete.submit();
        });

    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", () => {

        const searchInput = document.getElementById("{{searchId}}");

        // todos los productos (tabla + grid)
        const items = document.querySelectorAll(".product-item");

        // selects de filtros
        const selects = document.querySelectorAll(".filter-select");

        function applyFilters() {

            const query = (searchInput?.value || "")
                .toLowerCase()
                .trim();

            // obtener filtros activos
            const activeFilters = {};

            selects.forEach(sel => {
                if (sel.value) {
                    activeFilters[sel.id] = sel.value.toLowerCase();
                }
            });

            items.forEach(item => {

                //datos del producto
                const name = (item.dataset.name || "").toLowerCase();
                const category = (item.dataset.category || "").toLowerCase();
                const manufacturer = (item.dataset.manufacturer || "").toLowerCase();
                const active = (item.dataset.active || "").toLowerCase();
                const registration = (item.dataset.registration || "").toLowerCase();

                const matchSearch =
                    name.includes(query) ||
                    category.includes(query) ||
                    manufacturer.includes(query) ||
                    active.includes(query) ||
                    registration.includes(query);

                // filtros selects
                let matchFilters = true;

                for (const key in activeFilters) {

                    const value = activeFilters[key];

                    if (key.includes("category") && category !== value) matchFilters = false;
                    if (key.includes("manufacturer") && manufacturer !== value) matchFilters = false;
                    if (key.includes("status") && status !== value) matchFilters = false;
                    if (key.includes("active") && active !== value) matchFilters = false;
                }

                // mostrar / ocultar
                item.style.display = (matchSearch && matchFilters) ? "" : "none";
            });
        }

        //eventos
        if (searchInput) {
            searchInput.addEventListener("input", applyFilters);
        }

        selects.forEach(sel => {
            sel.addEventListener("change", applyFilters);
        });

    });
</script>