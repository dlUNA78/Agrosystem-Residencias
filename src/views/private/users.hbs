{{!-- ═══════════════════════════════════════════════════════════
     MODAL: Añadir / Editar Usuario
════════════════════════════════════════════════════════════ --}}
<div id="modal-user" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <div class="bg-surface-container-lowest rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden">
        <!-- Modal Header -->
        <div class="flex items-center justify-between px-8 py-6 border-b border-outline-variant/10">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary text-xl" data-icon="person_add">person_add</span>
                </div>
                <h2 class="text-base font-extrabold text-on-surface tracking-tight">Nuevo Usuario</h2>
            </div>
            <button id="btn-close-modal-user"
                class="p-2 rounded-lg text-on-surface-variant hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined" data-icon="close">close</span>
            </button>
        </div>
        <!-- Modal Body -->
        <form id="form-user" class="px-8 py-6 space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Nombre</label>
                    <input type="text" id="user-nombre" placeholder="Nombre(s)"
                        class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
                </div>
                <div>
                    <label class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Apellidos</label>
                    <input type="text" id="user-apellidos" placeholder="Apellidos"
                        class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
                </div>
            </div>
            <div>
                <label class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Correo Electrónico</label>
                <input type="email" id="user-email" placeholder="usuario@institución.mx"
                    class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
            </div>
            <div>
                <label class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Institución</label>
                <input type="text" id="user-institucion" placeholder="Nombre de la institución u organización"
                    class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Rol</label>
                    <select id="user-rol"
                        class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
                        <option value="">Seleccionar...</option>
                        <option value="admin">Admin</option>
                        <option value="investigador">Investigador</option>
                        <option value="tecnico">Técnico</option>
                        <option value="agricultor">Agricultor</option>
                    </select>
                </div>
                <div>
                    <label class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Estatus</label>
                    <select id="user-estatus"
                        class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
                        <option value="activo">Activo</option>
                        <option value="pendiente">Pendiente</option>
                        <option value="suspendido">Suspendido</option>
                    </select>
                </div>
            </div>
        </form>
        <!-- Modal Footer -->
        <div class="px-8 py-5 bg-surface-container-low/30 border-t border-outline-variant/10 flex justify-end gap-3">
            <button id="btn-cancel-modal-user"
                class="px-6 py-2.5 rounded-lg text-on-surface-variant text-sm font-bold hover:bg-surface-container-low transition-colors">
                Cancelar
            </button>
            <button type="submit" form="form-user"
                class="px-6 py-2.5 rounded-lg bg-[#43655c] text-white text-sm font-bold hover:bg-[#354f47] transition-colors shadow-lg shadow-primary/10 flex items-center gap-2">
                <span class="material-symbols-outlined text-base" data-icon="save">save</span>
                Guardar Usuario
            </button>
        </div>
    </div>
</div>

<script>
    // Modal toggle
    const modalUser     = document.getElementById('modal-user');
    const btnAddUser    = document.getElementById('btn-add-user');
    const btnCloseUser  = document.getElementById('btn-close-modal-user');
    const btnCancelUser = document.getElementById('btn-cancel-modal-user');

    const openModal  = () => modalUser.classList.replace('hidden', 'flex');
    const closeModal = () => modalUser.classList.replace('flex', 'hidden');

    btnAddUser?.addEventListener('click', openModal);
    btnCloseUser?.addEventListener('click', closeModal);
    btnCancelUser?.addEventListener('click', closeModal);
    modalUser?.addEventListener('click', (e) => { if (e.target === modalUser) closeModal(); });
</script>
