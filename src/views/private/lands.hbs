{{!-- ============================================================
     TERRENOS — Vista Principal: Mis Parcelas Experimentales
     ============================================================ --}}
<main class="min-h-screen flex flex-col">
    <div class="mt-20 p-10 space-y-8">

        {{!-- ── Cabecera ── --}}
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div>
                <h1 class="text-2xl font-extrabold text-[#0F2E2E]">Gestión de Terrenos y Parcelas</h1>
                <p class="text-sm text-on-surface-variant mt-1">Visualiza, registra y monitorea todos los predios del sistema.</p>
            </div>
        </div>


        {{!-- ── Mapa Leaflet ── --}}
        <section class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-50">
