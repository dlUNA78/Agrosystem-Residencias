                    <span class="material-symbols-outlined text-primary" data-icon="map">map</span>
                    <span class="font-bold text-[#0F2E2E] text-sm">Mapa de Predios</span>
                    <span class="text-[10px] bg-primary-container text-on-primary-container px-2 py-0.5 rounded-full font-bold uppercase ml-2">
