<script>
    (function () {
        // View toggle
        const tableView = document.getElementById('suppliers-table-view');
        const gridView = document.getElementById('suppliers-grid-view');
        const btnTable = document.getElementById('view-table');
        const btnGrid = document.getElementById('view-grid');

        if (btnTable && btnGrid) {
            btnGrid.classList.add('bg-[#43655c]', 'text-white');
            btnGrid.classList.remove('text-on-surface-variant');
            btnTable.classList.remove('bg-[#43655c]', 'text-white');
            btnTable.classList.add('text-on-surface-variant');

            btnTable.addEventListener('click', function () {
                tableView.style.display = '';
                gridView.style.display = 'none';
                btnTable.classList.add('bg-[#43655c]', 'text-white');
                btnTable.classList.remove('text-on-surface-variant');
                btnGrid.classList.remove('bg-[#43655c]', 'text-white');
                btnGrid.classList.add('text-on-surface-variant');
            });

            btnGrid.addEventListener('click', function () {
                tableView.style.display = 'none';
                gridView.style.display = 'grid';
                btnGrid.classList.add('bg-[#43655c]', 'text-white');
                btnGrid.classList.remove('text-on-surface-variant');
                btnTable.classList.remove('bg-[#43655c]', 'text-white');
                btnTable.classList.add('text-on-surface-variant');
            });
        }
    })();
</script>

{{!-- ═══════════════════════════════════════════════════════════
     MODAL: Añadir / Editar Proveedor
════════════════════════════════════════════════════════════ --}}
<div id="modal-supplier" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <div class="bg-surface-container-lowest rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden">
        <!-- Modal Header -->
        <div class="flex items-center justify-between px-8 py-6 border-b border-outline-variant/10">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary text-xl" data-icon="add_business">add_business</span>
                </div>
                <h2 class="text-base font-extrabold text-on-surface tracking-tight">Nuevo Proveedor</h2>
            </div>
            <button id="btn-close-modal-supplier"
                class="p-2 rounded-lg text-on-surface-variant hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined" data-icon="close">close</span>
            </button>
        </div>
        <!-- Modal Body -->
        <form id="form-supplier" class="px-8 py-6 space-y-4">
            <div>
                <label class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Nombre de la Empresa</label>
                <input type="text" id="supplier-nombre" placeholder="Razón social o nombre comercial"
                    class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">RFC</label>
                    <input type="text" id="supplier-rfc" placeholder="ABC123456XYZ"
                        class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
                </div>
                <div>
                    <label class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Teléfono</label>
                    <input type="text" id="supplier-telefono" placeholder="Número de contacto"
                        class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
                </div>
            </div>
            <div>
                <label class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Correo Electrónico</label>
                <input type="email" id="supplier-email" placeholder="contacto@empresa.com"
                    class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Tipo de Suministro</label>
                    <select id="supplier-tipo"
                        class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
                        <option value="">Seleccionar...</option>
                        <option value="agroquimicos">Agroquímicos</option>
                        <option value="semillas">Semillas</option>
                        <option value="equipo">Equipo</option>
                        <option value="servicios">Servicios</option>
                    </select>
                </div>
                <div>
                    <label class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Estatus</label>
                    <select id="supplier-estatus"
                        class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
                        <option value="activo">Activo</option>
                        <option value="pendiente">Pendiente</option>
                        <option value="inactivo">Inactivo</option>
                    </select>
                </div>
            </div>
        </form>
        <!-- Modal Footer -->
        <div class="px-8 py-5 bg-surface-container-low/30 border-t border-outline-variant/10 flex justify-end gap-3">
            <button id="btn-cancel-modal-supplier"
                class="px-6 py-2.5 rounded-lg text-on-surface-variant text-sm font-bold hover:bg-surface-container-low transition-colors">
                Cancelar
            </button>
            <button type="submit" form="form-supplier"
                class="px-6 py-2.5 rounded-lg bg-[#43655c] text-white text-sm font-bold hover:bg-[#354f47] transition-colors shadow-lg shadow-primary/10 flex items-center gap-2">
                <span class="material-symbols-outlined text-base" data-icon="save">save</span>
                Guardar Proveedor
            </button>
        </div>
    </div>
</div>

<script>
    // Modal toggle
    const modalSupplier     = document.getElementById('modal-supplier');
    const btnAddSupplier    = document.getElementById('btn-add-supplier');
    const btnAddSupplierCard = document.getElementById('btn-add-supplier-card');
    const btnCloseSupplier  = document.getElementById('btn-close-modal-supplier');
    const btnCancelSupplier = document.getElementById('btn-cancel-modal-supplier');

    const openModal  = () => modalSupplier.classList.replace('hidden', 'flex');
    const closeModal = () => modalSupplier.classList.replace('flex', 'hidden');

    btnAddSupplier?.addEventListener('click', openModal);
    btnAddSupplierCard?.addEventListener('click', openModal);
    btnCloseSupplier?.addEventListener('click', closeModal);
    btnCancelSupplier?.addEventListener('click', closeModal);
    modalSupplier?.addEventListener('click', (e) => { if (e.target === modalSupplier) closeModal(); });
</script>
