                    <!-- Row 2 -->
                    <tr class="hover:bg-surface/50 transition-colors">
                        <td class="px-8 py-5">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-[#115e59] flex items-center justify-center text-white font-extrabold text-sm shrink-0">
                                    BS</div>
