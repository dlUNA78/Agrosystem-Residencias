                                </div>
                            </div>
                        </td>
                        <td class="px-8 py-5">
                            <p class="text-sm font-medium text-on-surface">BSN050412ABC</p>
                        </td>
                        <td class="px-8 py-5">
                            <p class="text-sm text-on-surface">ventas@biosemillas.com</p>
                            <p class="text-xs text-on-surface-variant mt-0.5">+52 662 987 6543</p>
                        </td>
                        <td class="px-8 py-5 text-center">
                            <span class="px-3 py-1.5 bg-[#f59e0b]/10 text-[#d97706] rounded-full text-[10px] font-black uppercase">Semillas</span>
                        </td>
                        <td class="px-8 py-5 text-center">
                            <div class="flex items-center justify-center gap-1.5 text-amber-600 bg-amber-50 px-3 py-1.5 rounded-full border border-amber-100 mx-auto w-fit">
                                <span class="material-symbols-outlined text-sm" data-icon="schedule"
