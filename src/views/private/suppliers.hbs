<main class="min-h-screen flex flex-col">
    <!-- Content Area -->
    <div class="mt-20 p-12 space-y-10">

        {{!-- Control Bar & Search --}}
        {{> private/search-bar}}

        {{!-- Stats Bar --}}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <!-- TOTAL PROVEEDORES -->
            <div class="bg-surface-container-lowest rounded-xl border border-outline-variant/10 shadow-sm p-5 flex items-center gap-4">
                <div class="w-11 h-11 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-primary" data-icon="local_shipping"> local_shipping </span>
                </div>

                <div>
                    <p class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant"> Total Proveedores  </p>
                    <p class="text-2xl font-extrabold text-on-surface">  {{stats.total}} </p>
                </div>

            </div>
            <!-- ACTIVOS -->
            <div
                class="bg-surface-container-lowest rounded-xl border border-outline-variant/10 shadow-sm p-5 flex items-center gap-4">

                <div class="w-11 h-11 rounded-full bg-emerald-500/10 flex items-center justify-center shrink-0">

                    <span class="material-symbols-outlined text-emerald-600" data-icon="verified">
                        verified
                    </span>

                </div>

                <div>

                    <p class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant">
                        Activos
                    </p>

                    <p class="text-2xl font-extrabold text-on-surface">
                        {{stats.activos}}
                    </p>

                </div>

            </div>


            <!-- PENDIENTES -->
            <div class="bg-surface-container-lowest rounded-xl border border-outline-variant/10 shadow-sm p-5 flex items-center gap-4">
                <div class="w-11 h-11 rounded-full bg-amber-500/10 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-amber-600" data-icon="schedule">
                        schedule
                    </span>
                </div>

                <div>

                    <p class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant">
                        Pendientes
                    </p>

                    <p class="text-2xl font-extrabold text-on-surface">
                        {{stats.pendientes}}
                    </p>

                </div>

            </div>


            <!-- INACTIVOS -->
            <div
                class="bg-surface-container-lowest rounded-xl border border-outline-variant/10 shadow-sm p-5 flex items-center gap-4">

                <div class="w-11 h-11 rounded-full bg-error/10 flex items-center justify-center shrink-0">

                    <span class="material-symbols-outlined text-error" data-icon="block">
                        block
                    </span>

                </div>

                <div>

                    <p class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant">
                        Inactivos
                    </p>

                    <p class="text-2xl font-extrabold text-on-surface">
                        {{stats.inactivos}}
                    </p>

                </div>

            </div>

        </div>

        <!-- TABLE VIEW -->
        <div id="suppliers-table-view" style="display:none"
            class="bg-surface-container-lowest rounded-2xl shadow-sm overflow-hidden border border-outline-variant/10">
            <div class="overflow-x-auto">

                <table class="w-full min-w-[1500px] text-left border-collapse">

                    <thead>

                        <tr class="bg-surface-container-low/50">

                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Empresa
                            </th>

                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                RFC
                            </th>

                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Contacto
                            </th>

                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Ubicación
                            </th>

                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Suministro
                            </th>

                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Información comercial
                            </th>

                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                                Estatus
                            </th>

                            <th
                                class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-right">
                                Acciones
                            </th>

                        </tr>

                    </thead>


                    <tbody class="divide-y divide-outline-variant/10">

                        {{#each suppliers}}

                        <tr class="hover:bg-surface-container-low/50 transition-colors">
                            <!-- EMPRESA -->

                            <td class="px-8 py-5">
                                <div class="flex items-center gap-3">
                                    <div
                                        class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                                        <span class="material-symbols-outlined text-primary">
                                            business
                                        </span>
                                    </div>

                                    <div>
                                        <p class="text-sm font-bold text-on-surface"> {{name}} </p>
                                        {{#if commercial_name}}
                                        <p class="text-xs text-on-surface-variant"> {{commercial_name}} </p>
                                        {{/if}}
                                    </div>

                                </div>

                            </td>
                            <!-- RFC -->

                            <td class="px-8 py-5">
                                <p class="text-sm font-medium text-on-surface"> {{rfc}} </p>
                            </td>


                            <!-- CONTACTO -->

                            <td class="px-8 py-5">

                                <p class="text-sm font-bold text-on-surface">
                                    {{contact_name}}
                                </p>

                                {{#if contact_position}}

                                <p class="text-xs text-on-surface-variant">
                                    {{contact_position}}
                                </p>

                                {{/if}}

                                <p class="text-xs text-on-surface-variant mt-1">
                                    {{email}}
                                </p>

                                <p class="text-xs text-on-surface-variant">
                                    {{phone}}
                                </p>

                            </td>


                            <!-- UBICACIÓN -->

                            <td class="px-8 py-5">

                                <p class="text-sm text-on-surface">
                                    {{address}}
                                </p>

                                <p class="text-xs text-on-surface-variant">
                                    {{city}}, {{state}}
                                </p>

                                <p class="text-xs text-on-surface-variant">
                                    C.P. {{postal_code}}, {{country}}
                                </p>

                            </td>


                            <!-- SUMINISTRO -->

                            <td class="px-8 py-5">

                                <span
                                    class="inline-block px-3 py-1 rounded-full bg-primary/10 text-primary text-[10px] font-black uppercase">

                                    {{supply_type}}

                                </span>

                                <p class="text-xs text-on-surface-variant mt-2 max-w-[220px]">
                                    {{supplied_products}}
                                </p>

                                {{#if brands}}

                                <p class="text-xs text-on-surface-variant mt-1">

                                    <strong>Marcas:</strong> {{brands}}

                                </p>

                                {{/if}}

                            </td>


                            <!-- INFORMACIÓN COMERCIAL -->

                            <td class="px-8 py-5">

                                {{#if delivery_time}}

                                <p class="text-xs text-on-surface-variant">
                                    <strong>Entrega:</strong> {{delivery_time}}
                                </p>

                                {{/if}}


                                {{#if minimum_order}}

                                <p class="text-xs text-on-surface-variant mt-1">
                                    <strong>Compra mínima:</strong> ${{minimum_order}}
                                </p>

                                {{/if}}


                                {{#if payment_method}}

                                <p class="text-xs text-on-surface-variant mt-1">
                                    <strong>Pago:</strong> {{payment_method}}
                                </p>

                                {{/if}}

                            </td>


                            <!-- ESTATUS -->

                            <td class="px-8 py-5 text-center">

                                {{#if (eq status "activo")}}

                                <span
                                    class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-emerald-50 text-emerald-600 text-[10px] font-black uppercase">

                                    <span class="material-symbols-outlined text-sm">
                                        check_circle
                                    </span>

                                    Activo

                                </span>

                                {{else if (eq status "pendiente")}}

                                <span
                                    class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-amber-50 text-amber-600 text-[10px] font-black uppercase">

                                    <span class="material-symbols-outlined text-sm">
                                        schedule
                                    </span>

                                    Pendiente

                                </span>

                                {{else}}

                                <span
                                    class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-red-50 text-red-600 text-[10px] font-black uppercase">

                                    <span class="material-symbols-outlined text-sm">
                                        block
                                    </span>

                                    Inactivo

                                </span>

                                {{/if}}

                            </td>


                            <!-- ACCIONES -->

                            <td class="px-8 py-5">

                                <div class="flex items-center justify-end gap-2">
                                    <button type="button" class="btn-edit-supplier" data-id="{{id}}"
                                        data-name="{{name}}" data-commercial-name="{{commercial_name}}"
                                        data-rfc="{{rfc}}" data-supply-type="{{supply_type}}"
                                        data-contact-name="{{contact_name}}"
                                        data-contact-position="{{contact_position}}" data-email="{{email}}"
                                        data-alternative-email="{{alternative_email}}" data-phone="{{phone}}"
                                        data-alternative-phone="{{alternative_phone}}" data-address="{{address}}"
                                        data-city="{{city}}" data-state="{{state}}" data-postal-code="{{postal_code}}"
                                        data-country="{{country}}" data-supplied-products="{{supplied_products}}"
                                        data-brands="{{brands}}" data-delivery-time="{{delivery_time}}"
                                        data-minimum-order="{{minimum_order}}" data-payment-method="{{payment_method}}"
                                        data-status="{{status}}">
                                        <span class="material-symbols-outlined">
                                            edit
                                        </span>

                                    </button>
                                    <button type="button"
                                        class="btn-delete-supplier p-2 rounded-lg hover:bg-red-50 hover:text-red-600 transition-colors"
                                        title="Eliminar proveedor" data-id="{{id}}" data-name="{{name}}">

                                        <span class="material-symbols-outlined text-lg">
                                            delete
                                        </span>

                                    </button>

                                </div>

                            </td>

                        </tr>


                        {{else}}

                        <tr>

                            <td colspan="8" class="px-8 py-16 text-center">

                                <span class="material-symbols-outlined text-5xl text-on-surface-variant/30">
                                    business
                                </span>

                                <p class="mt-3 text-sm font-bold text-on-surface-variant">
                                    No hay proveedores registrados
                                </p>

                            </td>

                        </tr>

                        {{/each}}

                    </tbody>

                </table>

            </div>

            <!-- Pagination -->
            <div
                class="px-8 py-6 bg-surface-container-low/30 border-t border-outline-variant/10 flex items-center justify-between">
                <p class="text-xs font-medium text-on-surface-variant">
                    Mostrando
                    <span class="font-bold text-on-surface">
                        1 a {{suppliers.length}}
                    </span>
                    de
                    <span class="font-bold text-on-surface">
                        {{suppliers.length}}
                    </span>
                    registros
                </p>
                <div class="flex gap-2">
                    <button
                        class="px-5 py-2 rounded-lg bg-surface-container-highest/50 text-on-surface text-xs font-bold hover:bg-surface-container-highest transition-colors flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm" data-icon="chevron_left">chevron_left</span>
                        Anterior
                    </button>
                    <button
                        class="px-5 py-2 rounded-lg bg-[#43655c] text-white text-xs font-bold hover:bg-[#354f47] transition-colors flex items-center gap-2 shadow-sm">
                        Siguiente
                        <span class="material-symbols-outlined text-sm" data-icon="chevron_right">chevron_right</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- GRID VIEW -->
        <!-- GRID VIEW -->
        <div id="suppliers-grid-view" class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 grid">

            {{#each suppliers}}

            <div
                class="bg-surface-container-lowest rounded-xl border border-outline-variant/10 shadow-sm overflow-hidden hover:-translate-y-1 transition-all duration-300">

                <!-- HEADER DE LA TARJETA -->
                <div class="p-5 border-b border-outline-variant/10">

                    <div class="flex items-start justify-between gap-3">

                        <div class="flex items-center gap-3">

                            <div class="w-11 h-11 rounded-full bg-primary/10 flex items-center justify-center shrink-0">

                                <span class="material-symbols-outlined text-primary">
                                    business
                                </span>

                            </div>

                            <div>

                                <h3 class="text-sm font-extrabold text-on-surface">
                                    {{name}}
                                </h3>

                                {{#if commercial_name}}

                                <p class="text-xs text-on-surface-variant mt-0.5">
                                    {{commercial_name}}
                                </p>

                                {{/if}}

                            </div>

                        </div>

                        <!-- ESTATUS -->

                        {{#if (eq status "activo")}}

                        <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 shrink-0" title="Activo">
                        </span>

                        {{else if (eq status "pendiente")}}

                        <span class="w-2.5 h-2.5 rounded-full bg-amber-500 shrink-0" title="Pendiente">
                        </span>

                        {{else}}

                        <span class="w-2.5 h-2.5 rounded-full bg-red-500 shrink-0" title="Inactivo">
                        </span>

                        {{/if}}

                    </div>

                </div>


                <!-- INFORMACIÓN PRINCIPAL -->

                <div class="p-5 space-y-4">

                    <!-- RFC -->

                    <div class="flex items-start gap-3">

                        <span class="material-symbols-outlined text-base text-on-surface-variant">
                            badge
                        </span>

                        <div>

                            <p class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant">
                                RFC
                            </p>

                            <p class="text-xs font-bold text-on-surface mt-0.5">
                                {{rfc}}
                            </p>

                        </div>

                    </div>


                    <!-- CONTACTO -->

                    <div class="flex items-start gap-3">

                        <span class="material-symbols-outlined text-base text-on-surface-variant">
                            contact_phone
                        </span>

                        <div>

                            <p class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant">
                                Contacto
                            </p>

                            <p class="text-xs font-bold text-on-surface mt-0.5">
                                {{contact_name}}
                            </p>

                            <p class="text-xs text-on-surface-variant">
                                {{email}}
                            </p>

                            <p class="text-xs text-on-surface-variant">
                                {{phone}}
                            </p>

                        </div>

                    </div>


                    <!-- UBICACIÓN -->

                    <div class="flex items-start gap-3">

                        <span class="material-symbols-outlined text-base text-on-surface-variant">
                            location_on
                        </span>

                        <div>

                            <p class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant">
                                Ubicación
                            </p>

                            <p class="text-xs text-on-surface">
                                {{city}}, {{state}}
                            </p>

                            <p class="text-xs text-on-surface-variant">
                                C.P. {{postal_code}}
                            </p>

                        </div>

                    </div>


                    <!-- SUMINISTRO -->

                    <div>

                        <p class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant mb-1.5">
                            Suministro
                        </p>

                        <span
                            class="inline-block px-3 py-1 rounded-full bg-primary/10 text-primary text-[10px] font-black uppercase">

                            {{supply_type}}

                        </span>

                        <p class="text-xs text-on-surface-variant mt-2 line-clamp-2">
                            {{supplied_products}}
                        </p>

                    </div>


                    <!-- INFORMACIÓN COMERCIAL -->

                    <div class="pt-3 border-t border-outline-variant/10 space-y-1">

                        {{#if brands}}

                        <p class="text-xs text-on-surface-variant">
                            <strong>Marcas:</strong> {{brands}}
                        </p>

                        {{/if}}

                        {{#if delivery_time}}

                        <p class="text-xs text-on-surface-variant">
                            <strong>Entrega:</strong> {{delivery_time}}
                        </p>

                        {{/if}}

                        {{#if payment_method}}

                        <p class="text-xs text-on-surface-variant">
                            <strong>Pago:</strong> {{payment_method}}
                        </p>

                        {{/if}}

                    </div>

                </div>


                <!-- ACCIONES -->

                <div
                    class="px-5 py-4 bg-surface-container-low/30 border-t border-outline-variant/10 flex justify-end gap-2">

                    <button type="button" class="btn-edit-supplier" data-id="{{id}}" data-name="{{name}}"
                        data-commercial-name="{{commercial_name}}" data-rfc="{{rfc}}" data-supply-type="{{supply_type}}"
                        data-contact-name="{{contact_name}}" data-contact-position="{{contact_position}}"
                        data-email="{{email}}" data-alternative-email="{{alternative_email}}" data-phone="{{phone}}"
                        data-alternative-phone="{{alternative_phone}}" data-address="{{address}}" data-city="{{city}}"
                        data-state="{{state}}" data-postal-code="{{postal_code}}" data-country="{{country}}"
                        data-supplied-products="{{supplied_products}}" data-brands="{{brands}}"
                        data-delivery-time="{{delivery_time}}" data-minimum-order="{{minimum_order}}"
                        data-payment-method="{{payment_method}}" data-status="{{status}}">
                        <span class="material-symbols-outlined">
                            edit
                        </span>
                    </button>
                    <button type="button"
                        class="btn-delete-supplier p-2 rounded-lg hover:bg-red-50 hover:text-red-600 transition-colors"
                        title="Eliminar proveedor" data-id="{{id}}" data-name="{{name}}">

                        <span class="material-symbols-outlined text-lg">
                            delete
                        </span>

                    </button>

                </div>

            </div>

            {{else}}

            <div class="col-span-full py-16 text-center">

                <span class="material-symbols-outlined text-5xl text-on-surface-variant/30">
                    business
                </span>

                <p class="mt-3 text-sm font-bold text-on-surface-variant">
                    No hay proveedores registrados
                </p>

            </div>

            {{/each}}


            <!-- ADD NEW CARD -->

            <div id="btn-add-supplier-card"
                class="bg-surface-container-lowest rounded-xl border-2 border-dashed border-primary/20 shadow-sm overflow-hidden group hover:-translate-y-1 transition-all duration-300 flex items-center justify-center min-h-[220px] cursor-pointer">

                <div class="text-center p-6">

                    <span
                        class="material-symbols-outlined text-3xl text-primary/30 mb-2 group-hover:text-primary/50 transition-colors">
                        add_business
                    </span>

                    <p class="text-sm font-bold text-on-surface-variant group-hover:text-primary transition-colors">
                        Añadir proveedor
                    </p>

                </div>

            </div>

        </div>

    </div>
</main>

<script>
    (function () {
        // View toggle
        const tableView = document.getElementById('suppliers-table-view');
        const gridView = document.getElementById('suppliers-grid-view');
        const btnTable = document.getElementById('view-table');
        const btnGrid = document.getElementById('view-grid');

        if (btnTable && btnGrid) {
            btnGrid.classList.add('bg-[#43655c]', 'text-white');
            btnGrid.classList.remove('text-on-surface-variant');
            btnTable.classList.remove('bg-[#43655c]', 'text-white');
            btnTable.classList.add('text-on-surface-variant');

            btnTable.addEventListener('click', function () {
                tableView.style.display = '';
                gridView.style.display = 'none';
                btnTable.classList.add('bg-[#43655c]', 'text-white');
                btnTable.classList.remove('text-on-surface-variant');
                btnGrid.classList.remove('bg-[#43655c]', 'text-white');
                btnGrid.classList.add('text-on-surface-variant');
            });

            btnGrid.addEventListener('click', function () {
                tableView.style.display = 'none';
                gridView.style.display = 'grid';
                btnGrid.classList.add('bg-[#43655c]', 'text-white');
                btnGrid.classList.remove('text-on-surface-variant');
                btnTable.classList.remove('bg-[#43655c]', 'text-white');
                btnTable.classList.add('text-on-surface-variant');
            });
        }
    })();
</script>

{{!-- ═══════════════════════════════════════════════════════════
MODAL: Añadir / Editar Proveedor
════════════════════════════════════════════════════════════ --}}
<div id="modal-supplier" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">

    <div class="bg-surface-container-lowest rounded-2xl shadow-2xl w-full max-w-3xl max-h-[90vh] overflow-y-auto">

        <!-- Modal Header -->
        <div
            class="sticky top-0 z-10 bg-surface-container-lowest flex items-center justify-between px-8 py-6 border-b border-outline-variant/10">

            <div class="flex items-center gap-3">

                <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary text-xl">
                        add_business
                    </span>
                </div>

                <div>
                    <h2 id="supplier-modal-title" class="text-base font-extrabold text-on-surface tracking-tight">
                        Nuevo Proveedor
                    </h2>

                    <p class="text-xs text-on-surface-variant mt-0.5">
                        Registra la información completa del proveedor
                    </p>
                </div>

            </div>

            <button id="btn-close-modal-supplier" type="button"
                class="p-2 rounded-lg text-on-surface-variant hover:bg-surface-container-low transition-colors">

                <span class="material-symbols-outlined">
                    close
                </span>

            </button>

        </div>


        <!-- Modal Body -->
        <form id="form-supplier" action="/private/suppliers/create" method="POST" class="px-8 py-6 space-y-8">

            <!-- DATOS DE LA EMPRESA -->
            <!-- ================================================= -->

            <section>

                <div class="flex items-center gap-2 mb-4">

                    <span class="material-symbols-outlined text-primary">
                        business
                    </span>

                    <h3 class="text-sm font-extrabold text-on-surface">
                        Datos de la empresa
                    </h3>

                </div>


                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                    <!-- Nombre de la empresa -->
                    <div class="md:col-span-2">

                        <label
                            class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">

                            Nombre de la empresa

                        </label>

                        <input type="text" id="supplier-name" name="name" placeholder="Razón social de la empresa"
                            required
                            class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">

                    </div>


                    <!-- Nombre comercial -->
                    <div>

                        <label
                            class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">

                            Nombre comercial

                        </label>

                        <input type="text" id="supplier-commercial-name" name="commercial_name"
                            placeholder="Nombre con el que se conoce comercialmente"
                            class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">

                    </div>


                    <!-- RFC -->
                    <div>

                        <label
                            class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">

                            RFC

                        </label>

                        <input type="text" id="supplier-rfc" name="rfc" placeholder="ABC123456XYZ" maxlength="13"
                            required
                            class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">

                    </div>


                    <!-- Tipo de suministro -->
                    <div class="md:col-span-2">

                        <label
                            class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">

                            Tipo de suministro

                        </label>

                        <select id="supplier-supply-type" name="supply_type" required
