                            </div>
                        </td>
                        <td class="px-8 py-5">
                            <div class="flex justify-end gap-3 text-on-surface-variant">
                                <button class="hover:text-primary transition-colors" title="Ver detalle"><span
                                        class="material-symbols-outlined"
                                        data-icon="visibility">visibility</span></button>
                                <button class="hover:text-primary transition-colors" title="Editar"><span
                                        class="material-symbols-outlined" data-icon="edit">edit</span></button>
                                <button class="hover:text-error transition-colors" title="Inactivar"><span
                                        class="material-symbols-outlined" data-icon="block">block</span></button>
                            </div>
                        </td>
                    </tr>

                </tbody>
            </table>

            <!-- Pagination -->
            <div class="px-8 py-6 bg-surface-container-low/30 border-t border-outline-variant/10 flex items-center justify-between">
                <p class="text-xs font-medium text-on-surface-variant">
                    Mostrando <span class="font-bold text-on-surface">1 a 2</span> de <span
                        class="font-bold text-on-surface">15</span> registros
                </p>
                <div class="flex gap-2">
