                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                            RFC</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                            Contacto</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                            Tipo de Suministro</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                            Estatus</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-right">
                            Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-surface-container">

                    <!-- Row 1 -->
                    <tr class="hover:bg-surface/50 transition-colors">
                        <td class="px-8 py-5">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-on-primary font-extrabold text-sm shrink-0">
                                    AS</div>
                                <div>
                                    <p class="font-bold text-on-surface text-sm">AgroScience Labs S.A. de C.V.</p>
                                    <p class="text-xs text-on-surface-variant">Sinaloa, México</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-8 py-5">
                            <p class="text-sm font-medium text-on-surface">AGL981023XYZ</p>
                        </td>
                        <td class="px-8 py-5">
                            <p class="text-sm text-on-surface">contacto@agroscience.mx</p>
                            <p class="text-xs text-on-surface-variant mt-0.5">+52 667 123 4567</p>
                        </td>
                        <td class="px-8 py-5 text-center">
                            <span class="px-3 py-1.5 bg-primary/10 text-primary rounded-full text-[10px] font-black uppercase">Agroquímicos</span>
                        </td>
                        <td class="px-8 py-5 text-center">
                            <div class="flex items-center justify-center gap-1.5 text-emerald-600 bg-emerald-50 px-3 py-1.5 rounded-full border border-emerald-100 mx-auto w-fit">
                                <span class="material-symbols-outlined text-sm" data-icon="check_circle"
                                    data-weight="fill" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                                <span class="text-[10px] font-black uppercase">Activo</span>
                            </div>
                        </td>
                        <td class="px-8 py-5">
                            <div class="flex justify-end gap-3 text-on-surface-variant">
                                <button class="hover:text-primary transition-colors" title="Ver detalle"><span
                                        class="material-symbols-outlined"
                                        data-icon="visibility">visibility</span></button>
                                <button class="hover:text-primary transition-colors" title="Editar"><span
