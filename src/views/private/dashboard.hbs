                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 bg-primary-container rounded-full"></span>
                    <span class="text-xl font-bold" style="">Óptimo</span>
                </div>
            </div>
            <span class="material-symbols-outlined absolute -right-4 -bottom-4 text-8xl opacity-10"
                data-icon="verified_user" style="">verified_user</span>
        </div>
    </section>
    <div class="grid grid-cols-12 gap-10">
        <!-- Dashboard Overview Section (Expanded to full width since Validation Queue was removed) -->
        <section class="col-span-12 space-y-8">
            <div class="bg-surface-container-lowest rounded-2xl shadow-sm p-8">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h3 class="text-2xl font-bold text-[#0F2E2E]" style="">Resumen de Actividad</h3>
