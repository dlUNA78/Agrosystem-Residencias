                        </button>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                    <div class="p-6 rounded-xl bg-surface-container-low border border-surface-container">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="material-symbols-outlined text-primary" data-icon="forum" style="">forum</span>
                            <h4 class="text-sm font-bold text-on-surface" style="">Actividad del Foro</h4>
                        </div>
                        <p class="text-2xl font-extrabold text-[#0F2E2E]" style="">142 <span
                                class="text-xs font-medium text-on-surface-variant" style="">hilos nuevos</span></p>
