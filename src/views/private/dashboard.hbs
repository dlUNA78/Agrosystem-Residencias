                <div class="space-y-4">
                    <div
                        class="flex items-start gap-4 p-4 rounded-lg hover:bg-surface transition-colors border-l-2 border-transparent hover:border-primary">
                        <div
                            class="w-8 h-8 rounded-full bg-primary-container flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-xs text-on-primary-container" data-icon="update"
                                style="">update</span>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm font-bold text-on-surface" style="">Actualización de Ficha Técnica: Trigo
                                Fénix</p>
                            <p class="text-xs text-on-surface-variant" style="">Modificado por Dr. Ricardo Mendoza •
                                Hace 3 horas</p>
                        </div>
                    </div>
                    <div
                        class="flex items-start gap-4 p-4 rounded-lg hover:bg-surface transition-colors border-l-2 border-transparent hover:border-primary">
                        <div
                            class="w-8 h-8 rounded-full bg-secondary-container flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-xs text-on-secondary-container"
                                data-icon="person_add" style="">person_add</span>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm font-bold text-on-surface" style="">Nueva solicitud de acceso
                                institucional: Universidad Autónoma</p>
                            <p class="text-xs text-on-surface-variant" style="">5 nuevos investigadores pendientes de
