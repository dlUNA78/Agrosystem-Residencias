<!-- Main Content Canvas -->
<main class="ml-64 pt-24 px-10 pb-12 min-h-screen">
    <!-- Header Section -->
    <header class="mb-12">
        <h2 class="text-4xl font-extrabold text-[#0F2E2E] tracking-tight mb-2" style="">Panel de Administración</h2>
        <p class="text-on-surface-variant text-lg max-w-2xl" style="">Supervise la integridad de la base de datos y
            gestione el acceso de los usuarios a la plataforma Agrosystem.</p>
    </header>
    <!-- Stats Overview (Bento Style) -->
    <section class="grid grid-cols-12 gap-6 mb-12">
        <div
            class="col-span-12 md:col-span-4 bg-surface-container-lowest p-6 rounded-xl shadow-sm border-l-4 border-primary">
            <p class="text-on-surface-variant text-sm font-bold uppercase tracking-wider mb-2" style="">Pendientes de
                Validación</p>
            <div class="flex items-end gap-2">
                <span class="text-4xl font-extrabold text-[#0F2E2E]" style="">24</span>
                <span class="text-primary font-bold text-sm mb-1 pb-1" style="">+5 hoy</span>
            </div>
        </div>
        <div
            class="col-span-12 md:col-span-4 bg-surface-container-lowest p-6 rounded-xl shadow-sm border-l-4 border-secondary">
            <p class="text-on-surface-variant text-sm font-bold uppercase tracking-wider mb-2" style="">Usuarios Activos
            </p>
            <div class="flex items-end gap-2">
                <span class="text-4xl font-extrabold text-[#0F2E2E]" style="">1,284</span>
                <span class="text-primary font-bold text-sm mb-1 pb-1" style="">Inifap (42)</span>
            </div>
        </div>
        <div
            class="col-span-12 md:col-span-4 bg-primary text-on-primary p-6 rounded-xl shadow-lg relative overflow-hidden">
            <div class="relative z-10">
                <p class="text-primary-container text-sm font-bold uppercase tracking-wider mb-2" style="">Estado del
