                                <span
                                    class="px-3 py-1 bg-surface-container text-on-surface-variant rounded-full text-[10px] font-bold uppercase tracking-tight">Poaceae</span>
                            </div>
                        </td>
                        <td class="px-8 py-6 text-center">
                            <span
                                class="px-4 py-1.5 bg-blue-400/10 text-blue-700 rounded-full text-[10px] font-black uppercase">Primavera-Verano</span>
