                                    data-weight="fill" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                                <span class="text-[10px] font-black uppercase">Aprobado</span>
                            </div>
                        </td>
                        <td class="px-8 py-6">
                            <div class="flex justify-end gap-3 text-on-surface-variant">
                                <button class="hover:text-primary transition-colors"><span
                                        class="material-symbols-outlined"
                                        data-icon="visibility">visibility</span></button>
                                <button class="hover:text-primary transition-colors"><span
                                        class="material-symbols-outlined" data-icon="edit">edit</span></button>
                                <button class="hover:text-error transition-colors"><span
                                        class="material-symbols-outlined" data-icon="delete">delete</span></button>
                            </div>
                        </td>
                    </tr>
                    <!-- Row 3 -->
                    <tr class="hover:bg-surface/50 transition-colors">
                        <td class="px-8 py-6">
                            <img alt="Aguacate Hass"
                                class="w-20 h-14 rounded-lg object-cover bg-surface-container shadow-sm"
                                src="/images/test/aguacate_hass.png" />
                        </td>
                        <td class="px-8 py-6">
