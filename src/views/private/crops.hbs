                            <p class="text-xs italic text-on-surface-variant">Citrus latifolia</p>
                        </td>
                        <td class="px-8 py-6">
                            <div class="flex flex-wrap gap-2">
                                <span
                                    class="px-3 py-1 bg-primary-container text-on-primary-container rounded-full text-[10px] font-bold uppercase tracking-tight">Frutal</span>
