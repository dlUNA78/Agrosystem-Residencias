<main class="min-h-screen flex flex-col">
    <!-- Content Area -->
    <div class="mt-20 p-12 space-y-10">
        {{!-- Control Bar & Search --}}
        {{> private/search-bar}}



        <!-- Info Panel -->
        <div class="bg-emerald-50 border border-emerald-100 p-4 rounded-xl flex items-center justify-between shadow-sm">
            <div class="flex items-center gap-3">
                <div class="bg-emerald-100 p-2 rounded-full">
                    <span class="material-symbols-outlined text-emerald-700" data-icon="eco">eco</span>
                </div>
                <p class="text-emerald-900 font-medium text-sm tracking-tight">Hay <span class="font-bold">8
                        cultivos</span> pendientes de validación taxonómica por el equipo técnico.</p>
            </div>
            <button
                class="bg-white text-emerald-800 border border-emerald-200 px-5 py-2 rounded-lg text-xs font-bold hover:bg-emerald-100 transition-colors">
                Revisar Cultivos
            </button>
        </div>

        <!-- Alert Panel -->
        <div
            class="bg-blue-50 border border-blue-100 p-4 rounded-xl flex flex-wrap items-center justify-between gap-3 shadow-sm">
            <div class="flex items-center gap-3">
                <div class="bg-blue-100 p-2 rounded-full">
                    <span class="material-symbols-outlined text-blue-700" data-icon="info">info</span>
                </div>
                <p class="text-blue-900 font-medium text-sm tracking-tight">
                    Tienes <span class="font-bold">2 solicitudes</span> de nuevos cultivos pendientes de revisión
                    técnica.
                </p>
            </div>
            <button
                class="bg-white text-blue-800 border border-blue-200 px-5 py-2 rounded-lg text-xs font-bold hover:bg-blue-100 transition-colors">
                Revisar solicitudes
            </button>
        </div>

        {{!-- ══════════════════════════════════════════════════════════════
        TABLE VIEW
        ══════════════════════════════════════════════════════════════ --}}

        <div id="crops-table-view" style="display:none"
            class="bg-surface-container-lowest rounded-2xl shadow-sm overflow-hidden border border-outline-variant/10">

            <div class="overflow-x-auto">

                <table class="w-full text-left border-collapse">

                    {{!-- CABECERA --}}
                    <thead>

                        <tr class="bg-surface-container-low/50">

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Imagen
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Cultivo
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                                Clasificación
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                                Temporada
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                                Cosecha
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                                Estatus
                            </th>

                            <th
                                class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-right">
                                Acciones
                            </th>

                        </tr>

                    </thead>


                    {{!-- CUERPO --}}
                    <tbody class="divide-y divide-outline-variant/10">

                        {{#if crops}}

                        {{#each crops}}

                        <tr class="hover:bg-surface-container-low/30 transition-colors">


                            {{!-- ═════════════════════════════════════
                            IMAGEN
                            ══════════════════════════════════════ --}}

                            <td class="px-6 py-5">

                                <div class="w-16 h-16 rounded-xl overflow-hidden
                                            bg-emerald-50
                                            border border-emerald-100
                                            shadow-sm">

                                    {{#if image_url}}

                                    <img src="/{{image_url}}" alt="{{name}}" class="w-full h-full object-cover"
                                        onerror="this.onerror=null; this.src='/images/test/default.png';">

                                    {{else}}

                                    <img src="/images/test/default.png" alt="Sin imagen"
                                        class="w-full h-full object-cover">

                                    {{/if}}

                                </div>

                            </td>


                            {{!-- ═════════════════════════════════════
                            CULTIVO
                            ══════════════════════════════════════ --}}

                            <td class="px-6 py-5">

                                <div class="min-w-[210px]">

                                    <p class="font-bold text-on-surface text-sm">
                                        {{name}}
                                    </p>


                                    {{#if scientific_name}}

                                    <p class="text-xs italic text-on-surface-variant mt-1">
                                        {{scientific_name}}
                                    </p>

                                    {{/if}}


                                    {{#if variety}}

                                    <p class="text-[11px] text-on-surface-variant mt-2">

                                        <span class="font-semibold">
                                            Variedad:
                                        </span>

                                        {{variety}}

                                    </p>

                                    {{/if}}

                                </div>

                            </td>


                            {{!-- ═════════════════════════════════════
                            CLASIFICACIÓN
                            ══════════════════════════════════════ --}}

                            <td class="px-6 py-5">

                                <div class="space-y-2">

                                    {{#if category}}

                                    <span class="inline-flex
                                                     px-3 py-1
                                                     rounded-full
                                                     bg-emerald-50
                                                     text-emerald-700
                                                     text-[10px]
                                                     font-bold
                                                     uppercase">

                                        {{category}}

                                    </span>

                                    {{else}}

                                    <span class="text-xs text-on-surface-variant">
                                        Sin categoría
                                    </span>

                                    {{/if}}


                                    {{#if family}}

                                    <p class="text-xs text-on-surface-variant">

                                        <span class="font-semibold">
                                            Familia:
                                        </span>

                                        {{family}}

                                    </p>

                                    {{/if}}

                                </div>

                            </td>


                            {{!-- ═════════════════════════════════════
                            TEMPORADA
                            ══════════════════════════════════════ --}}

                            <td class="px-6 py-5 text-center">

                                {{#if season}}

                                <div class="inline-flex items-center gap-1">

                                    <span class="material-symbols-outlined text-sm text-emerald-700">
                                        calendar_month
                                    </span>

                                    <span class="text-xs font-medium text-on-surface">
                                        {{season}}
                                    </span>

                                </div>

                                {{else}}

                                <span class="text-xs text-on-surface-variant">
                                    No especificada
                                </span>

                                {{/if}}

                            </td>


                            {{!-- ═════════════════════════════════════
                            DÍAS DE COSECHA
                            ══════════════════════════════════════ --}}

                            <td class="px-6 py-5 text-center">

                                {{#if harvest_days}}

                                <div class="inline-flex items-center gap-1">

                                    <span class="material-symbols-outlined text-sm text-amber-600">
                                        schedule
                                    </span>

                                    <span class="text-xs font-medium text-on-surface">
                                        {{harvest_days}} días
                                    </span>

                                </div>

                                {{else}}

                                <span class="text-xs text-on-surface-variant">
                                    No especificado
                                </span>

                                {{/if}}

                            </td>


                            {{!-- ═════════════════════════════════════
                            ESTATUS
                            ══════════════════════════════════════ --}}

                            <td class="px-6 py-5 text-center">

                                {{#if (eq status "aprobado")}}

                                <span class="inline-flex items-center gap-1
                                                 px-3 py-1
                                                 rounded-full
                                                 bg-emerald-50
                                                 text-emerald-700
                                                 text-[10px]
                                                 font-bold
                                                 uppercase">

                                    <span class="material-symbols-outlined text-xs">
                                        check_circle
                                    </span>

                                    Aprobado

                                </span>


                                {{else if (eq status "rechazado")}}

                                <span class="inline-flex items-center gap-1
                                                 px-3 py-1
                                                 rounded-full
                                                 bg-red-50
                                                 text-red-700
                                                 text-[10px]
                                                 font-bold
                                                 uppercase">

                                    <span class="material-symbols-outlined text-xs">
                                        cancel
                                    </span>

                                    Rechazado

                                </span>


                                {{else}}

                                <span class="inline-flex items-center gap-1
                                                 px-3 py-1
                                                 rounded-full
                                                 bg-amber-50
                                                 text-amber-700
                                                 text-[10px]
                                                 font-bold
                                                 uppercase">

                                    <span class="material-symbols-outlined text-xs">
                                        schedule
                                    </span>

                                    Pendiente

                                </span>

                                {{/if}}

                            </td>


                            {{!-- ═════════════════════════════════════
                            ACCIONES
                            ══════════════════════════════════════ --}}

                            <td class="px-6 py-5">

                                <div class="flex items-center justify-end gap-2">


                                    {{!-- VER --}}
                                    <button type="button" class="view-crop-btn
                                               p-2
                                               rounded-lg
                                               hover:bg-emerald-50
                                               text-on-surface-variant
                                               hover:text-emerald-700
                                               transition-colors" title="Ver cultivo" data-id="{{id}}">

                                        <span class="material-symbols-outlined text-lg">
                                            visibility
                                        </span>

                                    </button>


                                    {{!-- EDITAR --}}
                                    <button type="button"
                                        class="edit-crop-btn p-2 rounded-lg hover:bg-blue-50 text-on-surface-variant hover:text-blue-700  transition-colors"
                                        title="Editar cultivo" data-id="{{id}}">
                                        <span class="material-symbols-outlined text-lg">
                                            edit
                                        </span>

                                    </button>


                                    {{!-- ELIMINAR --}}
                                    <button type="button" class="delete-crop-btn
                                               p-2
                                               rounded-lg
                                               hover:bg-red-50
                                               text-on-surface-variant
                                               hover:text-red-700
                                               transition-colors" title="Eliminar cultivo" data-id="{{id}}"
                                        data-name="{{name}}">

                                        <span class="material-symbols-outlined text-lg">
                                            delete
                                        </span>

                                    </button>

                                </div>

                            </td>

                        </tr>

                        {{/each}}


                        {{else}}

                        <tr>

                            <td colspan="7" class="px-8 py-20 text-center">

                                <span class="material-symbols-outlined
                                         text-6xl
                                         text-on-surface-variant/30">

                                    agriculture

                                </span>

                                <p class="mt-4
                                      text-sm
                                      font-bold
                                      text-on-surface-variant">

                                    No hay cultivos registrados

                                </p>

                                <p class="mt-1
                                      text-xs
                                      text-on-surface-variant/70">

                                    Agrega un cultivo para comenzar.

                                </p>

                            </td>

                        </tr>

                        {{/if}}

                    </tbody>

                </table>

            </div>


            {{!-- PAGINACIÓN --}}
            <div class="px-8 py-6
                bg-surface-container-low/30
                border-t
                border-outline-variant/10
                flex
                items-center
                justify-between">

                <p class="text-xs font-medium text-on-surface-variant">

                    Mostrando

                    <span class="font-bold text-on-surface">
                        {{crops.length}}
                    </span>

                    cultivos

                </p>


                <div class="flex gap-2">

                    <button type="button" class="px-5 py-2
                       rounded-lg
                       bg-surface-container-highest/50
                       text-on-surface
                       text-xs
                       font-bold
                       hover:bg-surface-container-highest
                       transition-colors
                       flex
                       items-center
                       gap-2">

                        <span class="material-symbols-outlined text-sm">
                            chevron_left
                        </span>

                        Anterior

                    </button>


                    <button type="button" class="px-5 py-2
                       rounded-lg
                       bg-[#43655c]
                       text-white
                       text-xs
                       font-bold
                       hover:bg-[#354f47]
                       transition-colors
                       flex
                       items-center
                       gap-2
                       shadow-sm">

                        Siguiente

                        <span class="material-symbols-outlined text-sm">
                            chevron_right
                        </span>

                    </button>

                </div>

            </div>

        </div>


        {{!-- ══════════════════════════════════════════════════════════════
        GRID VIEW
        ══════════════════════════════════════════════════════════════ --}}

        <div id="crops-grid-view" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">


            {{!-- AÑADIR CULTIVO --}}
            <div id="btn-add-crop-card" class="bg-surface-container-lowest
               rounded-xl
               border-2
               border-dashed
               border-primary/20
               shadow-sm
               overflow-hidden
               group
               hover:-translate-y-1
               transition-all
               duration-300
               flex
               items-center
               justify-center
               min-h-[220px]
               cursor-pointer">

                <div class="text-center p-6">

                    <span class="material-symbols-outlined
                         text-3xl
                         text-primary/30
                         mb-2
                         group-hover:text-primary/50
                         transition-colors">

                        agriculture

                    </span>

                    <p class="text-sm
                      font-bold
                      text-on-surface-variant
                      group-hover:text-primary
                      transition-colors">

                        Añadir cultivo

                    </p>

                </div>

            </div>


            {{#if crops}}

            {{#each crops}}


            {{!-- TARJETA --}}
            <div class="bg-surface-container-lowest
                        rounded-xl
                        border
                        border-outline-variant/10
                        shadow-sm
                        overflow-hidden
                        group
                        hover:-translate-y-1
                        transition-all
                        duration-300">


                {{!-- IMAGEN --}}
                <div class="relative
                            h-48
                            bg-emerald-50
                            overflow-hidden">

                    {{#if image_url}}

                    <img src="/{{image_url}}" alt="{{name}}" class="w-full
                                   h-full
                                   object-cover
                                   group-hover:scale-105
                                   transition-transform
                                   duration-500" onerror="this.onerror=null; this.src='/images/test/default.png';">

                    {{else}}

                    <img src="/images/test/default.png" alt="Sin imagen" class="w-full h-full object-cover">

                    {{/if}}


                    {{!-- ESTATUS --}}
                    <div class="absolute top-3 right-3">

                        {{#if (eq status "aprobado")}}

                        <span class="px-2.5
                                         py-1
                                         rounded-full
                                         bg-emerald-600
                                         text-white
                                         text-[10px]
                                         font-bold
                                         uppercase
                                         shadow-sm">

                            Aprobado

                        </span>


                        {{else if (eq status "rechazado")}}

                        <span class="px-2.5
                                         py-1
                                         rounded-full
                                         bg-red-600
                                         text-white
                                         text-[10px]
                                         font-bold
                                         uppercase
                                         shadow-sm">

                            Rechazado

                        </span>


                        {{else}}

                        <span class="px-2.5
                                         py-1
                                         rounded-full
                                         bg-amber-500
                                         text-white
                                         text-[10px]
                                         font-bold
                                         uppercase
                                         shadow-sm">

                            Pendiente

                        </span>

                        {{/if}}

                    </div>

                </div>


                {{!-- INFORMACIÓN --}}
                <div class="p-5">


                    {{!-- NOMBRE --}}
                    <div class="mb-4">

                        <h3 class="font-bold
                                   text-on-surface
                                   text-lg
                                   truncate">

                            {{name}}

                        </h3>


                        {{#if scientific_name}}

                        <p class="text-xs
                                      italic
                                      text-on-surface-variant
                                      mt-1
                                      truncate">

                            {{scientific_name}}

                        </p>

                        {{/if}}

                    </div>


                    {{!-- DATOS PRINCIPALES --}}
                    <div class="space-y-3 text-xs">


                        {{!-- CATEGORÍA --}}
                        <div class="flex items-center justify-between gap-3">

                            <span class="text-on-surface-variant">
                                Categoría
                            </span>

                            <span class="font-bold
                                         text-on-surface
                                         text-right
                                         truncate">

                                {{#if category}}

                                {{category}}

                                {{else}}

                                No especificada

                                {{/if}}

                            </span>

                        </div>


                        {{!-- FAMILIA --}}
                        {{#if family}}

                        <div class="flex items-center justify-between gap-3">

                            <span class="text-on-surface-variant">
                                Familia
                            </span>

                            <span class="font-medium
                                             text-on-surface
                                             text-right
                                             truncate">

                                {{family}}

                            </span>

                        </div>

                        {{/if}}


                        {{!-- VARIEDAD --}}
                        {{#if variety}}

                        <div class="flex items-center justify-between gap-3">

                            <span class="text-on-surface-variant">
                                Variedad
                            </span>

                            <span class="font-medium
                                             text-on-surface
                                             text-right
                                             truncate">

                                {{variety}}

                            </span>

                        </div>

                        {{/if}}


                        {{!-- TEMPORADA --}}
                        {{#if season}}

                        <div class="flex items-center justify-between gap-3">

                            <span class="text-on-surface-variant">
                                Temporada
                            </span>

                            <span class="font-medium
                                             text-on-surface
                                             text-right
                                             truncate">

                                {{season}}

                            </span>

                        </div>

                        {{/if}}


                        {{!-- DÍAS DE COSECHA --}}
                        {{#if harvest_days}}

                        <div class="flex items-center justify-between gap-3">

                            <span class="text-on-surface-variant">
                                Cosecha
                            </span>

                            <span class="font-medium
                                             text-on-surface
                                             text-right">

                                {{harvest_days}} días

                            </span>

                        </div>

                        {{/if}}

                    </div>


                    {{!-- ACCIONES --}}
                    <div class="flex
                                items-center
                                justify-end
                                gap-2
                                mt-5
                                pt-4
                                border-t
                                border-outline-variant/10">


                        {{!-- VER --}}
                        <button type="button" class="view-crop-btn
                                   p-2
                                   rounded-lg
                                   hover:bg-emerald-50
                                   text-on-surface-variant
                                   hover:text-emerald-700
                                   transition-colors" title="Ver cultivo" data-id="{{id}}">

                            <span class="material-symbols-outlined text-lg">
                                visibility
                            </span>

                        </button>

                        <button type="button"
                            class="edit-crop-btn p-2 rounded-lg hover:bg-blue-50 text-on-surface-variant hover:text-blue-700transition-colors"
                            title="Editar cultivo" data-id="{{id}}">
                            <span class="material-symbols-outlined text-lg">
                                edit
                            </span>

                        </button>
                        {{!-- ELIMINAR --}}
                        <button type="button" class="delete-crop-btn
                                   p-2
                                   rounded-lg
                                   hover:bg-red-50
                                   text-on-surface-variant
                                   hover:text-red-700
                                   transition-colors" title="Eliminar cultivo" data-id="{{id}}" data-name="{{name}}">

                            <span class="material-symbols-outlined text-lg">
                                delete
                            </span>

                        </button>

                    </div>

                </div>

            </div>

            {{/each}}


            {{else}}

            <div class="col-span-full
                    py-16
                    text-center">

                <span class="material-symbols-outlined
                         text-5xl
                         text-on-surface-variant/30">

                    agriculture

                </span>

                <p class="mt-3
                      text-sm
                      font-bold
                      text-on-surface-variant">

                    No hay cultivos registrados

                </p>

            </div>

            {{/if}}

        </div>
    </div>
</main>

<!-- MODAL: AÑADIR / EDITAR CULTIVO -->
<div id="modal-crop" class="fixed inset-0 z-[100] hidden items-center justify-center p-4">

    <!-- FONDO -->
    <div id="modal-crop-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm">
    </div>


    <!-- CONTENEDOR -->
    <div class="relative z-10 w-full max-w-5xl max-h-[92vh] overflow-y-auto bg-white rounded-2xl shadow-2xl">


        <!-- HEADER -->
        <div
            class="flex items-center justify-between px-6 py-5 border-b border-surface-container sticky top-0 bg-white z-20">

            <div>

                <h3 id="modal-crop-title" class="text-xl font-extrabold text-[#0F2E2E]">

                    Nuevo Cultivo

                </h3>

                <p class="text-xs text-on-surface-variant mt-1">

                    Registra toda la información técnica y agronómica del cultivo

                </p>

            </div>


            <button id="modal-crop-close" type="button"
                class="p-2 rounded-lg hover:bg-surface-container-low text-on-surface-variant transition-colors">

                <span class="material-symbols-outlined">
                    close
                </span>

            </button>

        </div>


        <!-- FORMULARIO -->
        <form id="crop-form" method="POST" action="/private/crops/create" enctype="multipart/form-data">


            <div class="p-6 space-y-10">


                <!-- ================================================= -->
                <!-- 1. IDENTIFICACIÓN Y CLASIFICACIÓN -->
                <!-- ================================================= -->

                <section>

                    <div class="flex items-center gap-2 mb-5">

                        <span class="material-symbols-outlined text-primary">
                            category
                        </span>

                        <div>

                            <h4 class="font-bold text-[#0F2E2E]">
                                Identificación y clasificación
                            </h4>

                            <p class="text-xs text-on-surface-variant">
                                Información taxonómica y clasificación del cultivo
                            </p>

                        </div>

                    </div>


                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">


                        <!-- Nombre común -->
                        <div>

                            <label class="block text-xs font-bold text-on-surface-variant mb-2">

                                Nombre común *

                            </label>

                            <input type="text" id="crop-name" name="name" required placeholder="Ej. Maíz Blanco"
                                class="w-full px-4 py-3 rounded-xl border border-outline-variant/30 bg-surface-container-low/30 focus:outline-none focus:ring-2 focus:ring-primary/30">

                        </div>


                        <!-- Nombre científico -->
                        <div>

                            <label class="block text-xs font-bold text-on-surface-variant mb-2">

                                Nombre científico *

                            </label>

                            <input type="text" id="crop-scientific-name" name="scientific_name" required
                                placeholder="Ej. Zea mays"
                                class="w-full px-4 py-3 rounded-xl border border-outline-variant/30 bg-surface-container-low/30 focus:outline-none focus:ring-2 focus:ring-primary/30">

                        </div>


                        <!-- Categoría -->
                        <div>

                            <label class="block text-xs font-bold text-on-surface-variant mb-2">

                                Categoría del cultivo *

                            </label>

                            <select id="crop-category" name="category" required
                                class="w-full px-4 py-3 rounded-xl border border-outline-variant/30 bg-surface-container-low/30">

                                <option value="">
                                    Seleccionar categoría
                                </option>

                                <option value="cereal">
                                    Cereal
                                </option>

                                <option value="frutal">
                                    Frutal
                                </option>

                                <option value="hortaliza">
                                    Hortaliza
                                </option>

                                <option value="leguminosa">
                                    Leguminosa
                                </option>

                                <option value="oleaginosa">
                                    Oleaginosa
                                </option>

                                <option value="tuberculo">
                                    Tubérculo
                                </option>

                                <option value="forrajera">
                                    Forrajera
                                </option>

                                <option value="ornamental">
                                    Ornamental
                                </option>

                                <option value="industrial">
                                    Industrial
                                </option>

                                <option value="otro">
                                    Otro
                                </option>

                            </select>

                        </div>


                        <!-- Familia -->
                        <div>

                            <label class="block text-xs font-bold text-on-surface-variant mb-2">

                                Familia botánica

                            </label>

                            <input type="text" id="crop-family" name="family" placeholder="Ej. Poaceae"
