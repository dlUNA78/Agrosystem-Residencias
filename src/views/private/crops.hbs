<main class="min-h-screen flex flex-col">
    <!-- Content Area -->
    <div class="mt-20 p-12 space-y-10">
        {{!-- Control Bar & Search --}}
        {{> private/search-bar}}



        <!-- Info Panel -->
        <div class="bg-emerald-50 border border-emerald-100 p-4 rounded-xl flex items-center justify-between shadow-sm">
            <div class="flex items-center gap-3">
                <div class="bg-emerald-100 p-2 rounded-full">
                    <span class="material-symbols-outlined text-emerald-700" data-icon="eco">eco</span>
                </div>
                <p class="text-emerald-900 font-medium text-sm tracking-tight">Hay <span class="font-bold">8
                        cultivos</span> pendientes de validación taxonómica por el equipo técnico.</p>
            </div>
            <button
                class="bg-white text-emerald-800 border border-emerald-200 px-5 py-2 rounded-lg text-xs font-bold hover:bg-emerald-100 transition-colors">
                Revisar Cultivos
            </button>
        </div>

        <!-- Data Grid -->
        <div class="bg-surface-container-lowest rounded-2xl shadow-sm overflow-hidden border border-outline-variant/10">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container-low/50">
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                            Imagen</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                            Detalles del Cultivo</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
                            Tipo / Familia</th>
                        <th
                            class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                            Temporada</th>
                        <th
                            class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-center">
                            Estatus</th>
                        <th
                            class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant text-right">
                            Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-surface-container">
                    <!-- Row 1 -->
                    <tr class="hover:bg-surface/50 transition-colors">
                        <td class="px-8 py-6">
                            <img alt="Maíz Blanco"
                                class="w-20 h-14 rounded-lg object-cover bg-surface-container shadow-sm"
                                src="/images/test/maiz_blanco.png" />
                        </td>
                        <td class="px-8 py-6">
                            <p class="font-bold text-on-surface text-sm">Maíz Blanco</p>
                            <p class="text-xs italic text-on-surface-variant">Zea mays</p>
                        </td>
                        <td class="px-8 py-6">
                            <div class="flex flex-wrap gap-2">
                                <span
                                    class="px-3 py-1 bg-primary-container text-on-primary-container rounded-full text-[10px] font-bold uppercase tracking-tight">Cereal</span>
                                <span
                                    class="px-3 py-1 bg-surface-container text-on-surface-variant rounded-full text-[10px] font-bold uppercase tracking-tight">Poaceae</span>
                            </div>
                        </td>
                        <td class="px-8 py-6 text-center">
                            <span
                                class="px-4 py-1.5 bg-blue-400/10 text-blue-700 rounded-full text-[10px] font-black uppercase">Primavera-Verano</span>
                        </td>
                        <td class="px-8 py-6 text-center">
                            <div
                                class="flex items-center justify-center gap-1.5 text-emerald-600 bg-emerald-50 px-3 py-1.5 rounded-full border border-emerald-100 mx-auto w-fit">
                                <span class="material-symbols-outlined text-sm" data-icon="check_circle"
                                    data-weight="fill" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                                <span class="text-[10px] font-black uppercase">Aprobado</span>
                            </div>
                        </td>
                        <td class="px-8 py-6">
                            <div class="flex justify-end gap-3 text-on-surface-variant">
                                <a href="/private/crops/maiz" class="hover:text-primary transition-colors"><span
                                        class="material-symbols-outlined"
                                        data-icon="visibility">visibility</span></a>
                                <button class="hover:text-primary transition-colors"><span
                                        class="material-symbols-outlined" data-icon="edit">edit</span></button>
                                <button class="hover:text-error transition-colors"><span
                                        class="material-symbols-outlined" data-icon="delete">delete</span></button>
                            </div>
                        </td>
                    </tr>
