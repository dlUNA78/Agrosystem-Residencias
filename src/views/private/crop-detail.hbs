<!-- Biological Cycle (Timeline Style like SCREEN_23) -->
<div class="bg-surface-container-low py-20 mb-24">
<div class="max-w-7xl mx-auto px-4 md:px-10">
<div class="mb-12">
<h2 class="text-3xl font-extrabold tracking-tight mb-4">Ciclo de Cultivo</h2>
<p class="text-on-surface-variant max-w-2xl">Etapas cronológicas desde la siembra hasta la cosecha final bajo condiciones óptimas.</p>
</div>
<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
<!-- Step 1 -->
<div class="relative flex flex-col items-center text-center">
<div class="w-16 h-16 rounded-full bg-[#0F2E2E] text-white flex items-center justify-center text-xl font-bold mb-6 z-10">1</div>
<div class="hidden md:block absolute top-8 left-1/2 w-full h-[2px] bg-[#0F2E2E]/20"></div>
<h4 class="font-bold text-lg mb-2">Siembra - Germinación</h4>
<p class="text-sm text-on-surface-variant leading-relaxed">Días 0 - 10. Requiere humedad constante y temperaturas sobre 15°C.</p>
</div>
<!-- Step 2 -->
<div class="relative flex flex-col items-center text-center">
<div class="w-16 h-16 rounded-full bg-[#0F2E2E] text-white flex items-center justify-center text-xl font-bold mb-6 z-10">2</div>
<div class="hidden md:block absolute top-8 left-1/2 w-full h-[2px] bg-[#0F2E2E]/20"></div>
<h4 class="font-bold text-lg mb-2">Desarrollo Vegetativo</h4>
<p class="text-sm text-on-surface-variant leading-relaxed">Días 11 - 60. Rápido crecimiento foliar. Máxima demanda de nitrógeno.</p>
</div>
<!-- Step 3 -->
<div class="relative flex flex-col items-center text-center">
<div class="w-16 h-16 rounded-full bg-[#0F2E2E] text-white flex items-center justify-center text-xl font-bold mb-6 z-10">3</div>
<div class="hidden md:block absolute top-8 left-1/2 w-full h-[2px] bg-[#0F2E2E]/20"></div>
<h4 class="font-bold text-lg mb-2">Floración</h4>
<p class="text-sm text-on-surface-variant leading-relaxed">Días 61 - 80. Etapa crítica. Sensible al estrés hídrico. Emisión de espiga.</p>
</div>
<!-- Step 4 -->
<div class="relative flex flex-col items-center text-center">
<div class="w-16 h-16 rounded-full bg-[#0F2E2E] text-white flex items-center justify-center text-xl font-bold mb-6 z-10">4</div>
<h4 class="font-bold text-lg mb-2">Maduración y Cosecha</h4>
<p class="text-sm text-on-surface-variant leading-relaxed">Días 81 - 120+. Llenado de grano y secado. Reducción de agua.</p>
</div>
</div>
</div>
</div>
