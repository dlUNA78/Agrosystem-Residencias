{{!-- ═══════════════════════════════════════════════════════════
MODAL: Añadir / Editar Ingrediente Activo
════════════════════════════════════════════════════════════ --}}
<div id="modal-ingredient"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <div class="bg-surface-container-lowest rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden">
        <!-- Modal Header -->
        <div class="flex items-center justify-between px-8 py-6 border-b border-outline-variant/10">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary text-xl" data-icon="science">science</span>
                </div>
                <h2 class="text-base font-extrabold text-on-surface tracking-tight">Nuevo Ingrediente Activo</h2>
            </div>
            <button id="btn-close-modal-ingredient"
                class="p-2 rounded-lg text-on-surface-variant hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined" data-icon="close">close</span>
            </button>
        </div>
        <!-- Modal Body -->
        <form id="form-ingredient" class="px-8 py-6 space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label
                        class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Nombre
                        Común</label>
                    <input type="text" id="ingredient-nombre" placeholder="Ej. Glifosato"
                        class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
                </div>
                <div>
                    <label
                        class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Nombre
                        IUPAC</label>
                    <input type="text" id="ingredient-iupac" placeholder="Nombre químico sistemático"
                        class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
                </div>
            </div>
            <div>
                <label
                    class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Grupo
                    Químico</label>
                <input type="text" id="ingredient-grupo" placeholder="Ej. Organofosforados, Neonicotinoides..."
                    class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
            </div>
            <div>
                <label
                    class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Mecanismo
                    de Acción</label>
                <input type="text" id="ingredient-mecanismo" placeholder="Ej. Inhibidor EPSPS, Agonista nAChR..."
                    class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
            </div>
            <div class="grid grid-cols-3 gap-4">
                <div>
                    <label
                        class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Tipo
                        de Acción</label>
                    <select id="ingredient-tipo"
                        class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
                        <option value="">Seleccionar...</option>
                        <option value="herbicida">Herbicida</option>
                        <option value="insecticida">Insecticida</option>
                        <option value="fungicida">Fungicida</option>
                        <option value="acaricida">Acaricida</option>
                        <option value="nematicida">Nematicida</option>
                        <option value="bactericida">Bactericida</option>
                    </select>
                </div>
                <div>
                    <label
                        class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Toxicidad
                        OMS</label>
                    <select id="ingredient-toxicidad"
                        class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
                        <option value="">Seleccionar...</option>
                        <option value="clase-i">Clase I — Extremadamente tóxico</option>
                        <option value="clase-ii">Clase II — Altamente tóxico</option>
                        <option value="clase-iii">Clase III — Moderadamente tóxico</option>
                        <option value="clase-iv">Clase IV — Ligeramente tóxico</option>
                        <option value="u">U — Poco probable</option>
                    </select>
                </div>
                <div>
                    <label
                        class="text-[10px] uppercase tracking-widest font-black text-on-surface-variant block mb-1.5">Estatus</label>
                    <select id="ingredient-estatus"
                        class="w-full px-4 py-3 bg-surface-container-low rounded-lg text-sm border-none focus:ring-2 focus:ring-primary/20">
                        <option value="aprobado">Aprobado</option>
                        <option value="pendiente">Pendiente</option>
                        <option value="restringido">Restringido</option>
                    </select>
                </div>
            </div>
        </form>
        <!-- Modal Footer -->
        <div class="px-8 py-5 bg-surface-container-low/30 border-t border-outline-variant/10 flex justify-end gap-3">
            <button id="btn-cancel-modal-ingredient"
                class="px-6 py-2.5 rounded-lg text-on-surface-variant text-sm font-bold hover:bg-surface-container-low transition-colors">
                Cancelar
            </button>
            <button type="submit" form="form-ingredient"
                class="px-6 py-2.5 rounded-lg bg-[#43655c] text-white text-sm font-bold hover:bg-[#354f47] transition-colors shadow-lg shadow-primary/10 flex items-center gap-2">
                <span class="material-symbols-outlined text-base" data-icon="save">save</span>
                Guardar Ingrediente
            </button>
        </div>
    </div>
</div>

<script>
    // Modal toggle
    const modalIngredient = document.getElementById('modal-ingredient');
    const btnAddIngredient = document.getElementById('btn-add-ingredient');
    const btnCloseIngredient = document.getElementById('btn-close-modal-ingredient');
    const btnCancelIngredient = document.getElementById('btn-cancel-modal-ingredient');

    const openModal = () => modalIngredient.classList.replace('hidden', 'flex');
    const closeModal = () => modalIngredient.classList.replace('flex', 'hidden');

    btnAddIngredient?.addEventListener('click', openModal);
    btnCloseIngredient?.addEventListener('click', closeModal);
    btnCancelIngredient?.addEventListener('click', closeModal);
    modalIngredient?.addEventListener('click', (e) => { if (e.target === modalIngredient) closeModal(); });
</script>