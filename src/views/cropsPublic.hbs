                        <option>Región</option>
                        <option>Norte</option>
                        <option>Bajío</option>
                        <option>Sureste</option>
                    </select>
                    <select
                        class="bg-surface-container-lowest border-none rounded-xl py-4 px-6 text-sm font-semibold text-on-surface-variant focus:ring-2 focus:ring-primary/20 appearance-none min-w-[140px]">
